    ambush_pending      = false, -- true during the brief delay between ambush detection and the actual teleport
    ambush_stop_ratio   = nil,   -- path ratio where a mid-journey ambush froze dot promotion
    ambush_range_ids    = {},    -- buried device_pda ids forming the PDA ambush-range ring
    ambush_range_last   = nil,   -- {radius,cx,cz} cache to avoid rebuilding the ring every tick
    target_stamina      = 1.0, -- end-of-travel stamina the post-arrival safety window should hold at
    path_preview_id     = nil,
