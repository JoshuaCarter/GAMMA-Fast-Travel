    emission_time_jump_secs  = nil, -- game seconds to advance at interrupt (secs_until - lead)
    emission_interrupt_pending = false,
    graph_cache         = nil,  -- [{gvid, lvid, pos}] on current level
    graph_lvid_map      = nil,  -- [lvid] = gvid
    graph_cache_level   = nil,
    graph_cache_name    = nil,
    door_pos_cache      = nil,  -- [vector] transition-trigger positions leading out of the current level
    door_pos_cache_level = nil,
    menu_resolve_cache  = nil,  -- { seq, id, ln, target, err } — one resolve per map menu open
    menu_path_cache     = nil,  -- { seq, id, chain, is_vertex, path_len, raw_chain } — one path build per menu open
    encumbrance_time_mult = 1.0,
    encumbrance_speed_mult = 1.0,
    path_chain          = nil, -- polyline (vector list) for the active journey; authoritative for
                                -- display dots, ambush ratio->position, and interrupt teleports.
    path_chain_is_vertex = nil,
}
_G.dft = _G.dft or {}
for key, value in pairs(dft_defaults) do
    if _G.dft[key] == nil then
        _G.dft[key] = value
    end
end
local dft = _G.dft

