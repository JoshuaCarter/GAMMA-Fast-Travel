function dft_format_msg(fmt, ...)
    local arg = {...}
    if #arg == 0 then return tostring(fmt) end
    local ok, res = pcall(string.format, fmt, ...)
    return ok and res or (tostring(fmt) .. " (format error)")
end

function dft_log(fmt, ...)
    local cfg = _G.dft_config
    if not (cfg and cfg.debug_log) then return end
    printf("[DFT] " .. dft_format_msg(fmt, ...))
end

function dft_path_road_log_enabled()
    local cfg = _G.dft_config
    if cfg and cfg.debug_log then return true end
    if cfg and cfg.path_preview and dft.is_path_preview then return true end
    return false
end

function dft_path_road_log(fmt, ...)
    if not dft_path_road_log_enabled() then return end
    printf("[DFT path-road] " .. dft_format_msg(fmt, ...))
end

function dft_log_error(fmt, ...)
    printf("[DFT ERROR] " .. dft_format_msg(fmt, ...))
end

-- Player-facing text: edit gamedata/configs/text/eng/st_dorn_fast_travel.xml
-- Display via dft_msg() / dft_str(); MCM labels stay in ui_mcm_dorn_fast_travel.xml
function dft_str(id)
    local s = game.translate_string(id)
    if s and s ~= "" and s ~= id then return s end
    return id
end

function dft_destination_on_other_level(obj)
    if not (obj and db.actor) then return false end
    local gg = game_graph()
    if not gg then return false end
    local ok_a, actor_lid = pcall(function() return gg:vertex(db.actor:game_vertex_id()):level_id() end)
    local ok_d, dest_lid = pcall(function() return gg:vertex(obj.m_game_vertex_id):level_id() end)
    return ok_a and ok_d and actor_lid ~= dest_lid
end

-- True when object's game-graph level matches the actor's loaded level (not PDA tab name).
function dft_object_on_loaded_level(se_obj)
    if not (se_obj and db.actor and game_graph) then return true end
    local gg = game_graph()
    local obj_gvid = se_obj.m_game_vertex_id
    if not (obj_gvid and gg.valid_vertex_id and gg:valid_vertex_id(obj_gvid)) then
        return not dft_destination_on_other_level(se_obj)
    end
    local ok_a, actor_lid = pcall(function() return gg:vertex(db.actor:game_vertex_id()):level_id() end)
    local ok_o, obj_lid = pcall(function() return gg:vertex(obj_gvid):level_id() end)
    return ok_a and ok_o and actor_lid == obj_lid
end


function dft_is_cross_zone_destination(se_obj, ln)
    local cur_lvl = (level and level.name) and level.name() or nil
    if ln and cur_lvl and ln ~= cur_lvl then return true end
    if se_obj then return dft_destination_on_other_level(se_obj) end
    return false
end

function dft_dbg(order, msg, color)
    local cfg = _G.dft_config
    local dft_dorn = _G.dft.dorn
    if dft_dorn and dft_dorn.dbg and cfg and cfg.debug_overlay then
        dft_dorn.dbg.write("dorn_fast_travel", order, msg, color)
    end
end

function dft_dbg_clear()
    local dft_dorn = _G.dft.dorn
    if dft_dorn and dft_dorn.dbg then
        dft_dorn.dbg.clear_source("dorn_fast_travel")
    end
end

function dft_safe_create_item(section, fallback)
    if not db or not db.actor then return end
    local ini = system_ini()
    if section and ini:section_exist(section) then
        alife_create_item(section, db.actor)
    elseif fallback and ini:section_exist(fallback) then
        dft_log("SAFE CREATE: Section %s missing, falling back to %s", tostring(section), tostring(fallback))
        alife_create_item(fallback, db.actor)
    else
        dft_log("SAFE CREATE ERROR: Section %s and fallback missing!", tostring(section))
    end
end

function dft_is_trader_restrictor(name)
    if not name then return false end
    local low_name = string.lower(name)
    return string.find(low_name, "trader") ~= nil
        or string.find(low_name, "merchant") ~= nil
        or string.find(low_name, "barman") ~= nil
        or string.find(low_name, "sidorovich") ~= nil
        or string.find(low_name, "saharov") ~= nil
        or string.find(low_name, "forester") ~= nil
end

-- %c[] prefixes work reliably in news_manager.send_tip.
local dft_msg_style_prefix_map = {
    danger  = "%c[255,238,28,36]",
    warning = "%c[255,209,209,56]",
    success = "%c[255,56,209,115]",
}

local dft_msg_style_icon_map = {
    danger  = "ui_inGame2_radiation_hard",
    warning = "ui_inGame2_radiation_middle",
}

function dft_msg_style_prefix(style)
    return (style and dft_msg_style_prefix_map[style]) or ""
end

function dft_msg_style_icon(style)
    return (style and dft_msg_style_icon_map[style]) or nil
end

dft_msg = function(text, style)
    if not (db.actor and db.actor:alive()) then return end
    local prefix = dft_msg_style_prefix(style)
    if prefix ~= "" then
        text = prefix .. text
    end
    local icon = dft_msg_style_icon(style)
    local refresh = _G.refresh_active_config or refresh_active_config
    local cfg = dft.active_config or (refresh and refresh()) or {}
    local duration = tonumber(cfg.message_duration) or 30
    -- send_tip uses milliseconds and honors long durations; actor_menu.set_msg ignores MCM values.
    if news_manager and news_manager.send_tip then
        news_manager.send_tip(db.actor, text, nil, icon, duration * 1000)
    elseif actor_menu and actor_menu.set_msg then
        actor_menu.set_msg(1, text, duration)
    end
end

-- dft_publish_to_global
do
    _G.dft_config = _G.dft_config or {}
    _G.dft_format_msg = dft_format_msg
    _G.dft_log = dft_log
    _G.dft_path_road_log_enabled = dft_path_road_log_enabled
    _G.dft_path_road_log = dft_path_road_log
    _G.dft_log_error = dft_log_error
    _G.dft_str = dft_str
    _G.dft_destination_on_other_level = dft_destination_on_other_level
    _G.dft_object_on_loaded_level = dft_object_on_loaded_level
    _G.dft_is_cross_zone_destination = dft_is_cross_zone_destination
    _G.dft_dbg = dft_dbg
    _G.dft_dbg_clear = dft_dbg_clear
    _G.dft_safe_create_item = dft_safe_create_item
    _G.dft_is_trader_restrictor = dft_is_trader_restrictor
    _G.dft_msg = dft_msg
    _G.dft_msg_style_prefix = dft_msg_style_prefix
    _G.dft_msg_style_icon = dft_msg_style_icon
    printf("[DFT] core module loaded")
end
