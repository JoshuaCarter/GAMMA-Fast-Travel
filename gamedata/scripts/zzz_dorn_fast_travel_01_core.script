    arrival_ambush_targets = nil,
    emission_interrupt_ratio = nil, -- 0-1 path fraction when scheduled emission hits
    emission_time_jump_secs  = nil, -- game seconds to advance at interrupt (secs_until - lead)
    emission_interrupt_pending = false,
    graph_cache         = nil,  -- [{gvid, lvid, pos}] on current level
    graph_lvid_map      = nil,  -- [lvid] = gvid
    graph_cache_level   = nil,
    graph_cache_name    = nil,
    menu_resolve_cache  = nil,  -- { seq, id, ln, target, err } — one resolve per map menu open
