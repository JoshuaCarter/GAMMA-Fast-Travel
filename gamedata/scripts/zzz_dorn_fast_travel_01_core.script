-- Integer game hours from level.get_time_hours() (0-23).
-- day:      07-19  full daylight, widest ambush scan
-- twilight: 06-07 dawn, 19-20 dusk  reduced visibility (tighter ambush scan)
-- night:    20-06  dark hours, lowest visibility (tightest ambush scan)
_G.dft_time_of_day = {
    day_start           = 7,
    day_end             = 19,
    twilight_dawn_start = 6,
    twilight_dawn_end   = 7,
    twilight_dusk_start = 19,
    twilight_dusk_end   = 20,
    night_start         = 20,
    night_end           = 6,
}

_G.dft_arrival = {
    reroute_max = 10,
}

-- Zone-transition combat lock: hard-disables every level transition trigger on the current
-- level (native engine flag via game_object:enable_level_changer - not a position clamp) while
-- an alerted enemy is actively engaging the actor within ambush range. Applies regardless of
-- how the actor got there - on foot, or just dropped off at a zone exit by this mod's own fast
-- travel - and regardless of where on the level they're standing. Reuses dft_ambush_radius_m
-- for the "is anyone alerted nearby" range so it's already forgiving at night/in bad weather,
-- same as every other ambush check in this mod.
_G.dft_transition_guard = {
    buffer_m         = 12, -- how close to a door counts as "near it" for the on-screen warning
    search_pad_m     = 15, -- extra search radius added on top of buffer_m when locating that door
    scan_interval_ms = 150,
    msg_cooldown_s   = 5,
}

_G.dft_path = {
    dot_spot              = "dft_path_dot",
    dot_spot_pending      = "dft_path_dot_pending",
    dot_spot_ambush       = "dft_path_dot_ambush", -- red: an ambush happened around here
    dot_spot_dodge        = "dft_path_dot_dodge",  -- blue: a threat was dodged around here
    dot_spot_debug_vertex = "dft_path_debug_vertex",
    dot_spot_debug_edge   = "dft_path_debug_edge",
    dot_max_count         = 1000,
    dot_spacing_m         = 20,  -- journey dots every 20m along generated path
    dot_underground_offset_m = 100, -- bury the carrier device_pda this far below its dot's
                                     -- real y so it's never visible/reachable in the 3D world -
                                     -- map spots only care about x/z, so this doesn't affect them.
    ambush_range_segments = 32,  -- ring markers approximating ambush radius on the PDA map
    ambush_range_spot     = "dft_ambush_range_ring",
    road_on_graph_max_m   = 5,   -- navmesh counts as on-road when this close to a graph node
    preview_edge_spacing_m = 5,
    lc_snap_max_drift_m   = 25,  -- max navmesh snap distance from level changer
    ground_snap_max_drift_m = 60,
    graph_nearest_max_m   = 50,  -- tight graph lookup for transitions

    -- Navmesh A* pathfinder (dft_astar_navmesh_path). Walks level.vertex_in_direction,
    -- the same mesh-constrained stepping primitive the engine's AI uses, so every hop is
    -- guaranteed to stay on walkable ground (no underground/void jumps).
    nav_step_m            = 18,   -- horizontal distance per mesh-walk hop
    nav_max_nodes         = 1500, -- hard cap on expanded search nodes (perf safety)
    nav_goal_tol_m        = 12,   -- close enough to destination vertex to stop searching
    nav_dir_count         = 10,   -- direction fan size per node expansion (relative to goal bearing)
    -- Roads are strongly preferred, but only when a road hop still nets closer to the
    -- destination afterward (see the "progressing" check in dft_astar_navmesh_path) - a
    -- road that leads away/sideways gets no discount, so the search won't detour onto it.
    nav_road_cost_mult    = 0.15, -- cost multiplier for progressing hops near a road vertex
    nav_road_seek_m       = 45,   -- search radius for the "hop straight at nearest road node" candidate
    nav_min_move_frac     = 0.35, -- min fraction of intended hop distance to count as unobstructed
    nav_min_move_abs_m    = 1.2,  -- absolute floor (m) - whichever of this or the fraction is smaller wins,
                                   -- so short real progress near walls/corners isn't thrown away just because
                                   -- it's a small % of a long requested hop (see dft_mesh_step_ok in 05_path)
    nav_heuristic_weight  = 1.05, -- >1 = faster/greedier search, still near-optimal
    nav_smooth_step_m     = 15,   -- hop size used while validating shortcut line-of-sight
    nav_smooth_tolerance_m = 3,   -- allowed endpoint drift when validating a shortcut
    nav_incomplete_gap_mult = 2.5, -- reject partial A* results if final gap > nav_step_m * this
}

