    encumbrance_red_speed      = 0.5,
    encumbrance_red_stamina    = 0.10, -- end-of-travel stamina when arriving over max carry weight
    ambush_stamina_normal      = 0.50, -- end-of-travel stamina when ambushed in normal (non-sneak) mode
    ambush_stamina_sneaky      = 1.00, -- end-of-travel stamina when ambushed while sneaking
}

-- Guide fee scales with how dangerous the origin/destination levels are on average (1.0 safest
-- - 2.0 most dangerous, see dft_get_level_danger below). dft_guide_cost_per_km (the rate at
-- cost multiplier 1.0, i.e. the safest possible route) x that multiplier is tuned so a guide
-- trip costs roughly 2x what FFT's own guide travel would charge for the same trip (FFT default:
-- 1500 RU/km flat, x(1 + avg map hazard 0.5-2.0) - hazard scaling applies by default regardless
-- of FFT's "progressive cost" toggle) at every danger level, not just on average.
_G.dft_guide_danger_mid = 1.3 -- fallback for any level missing from guide_danger.ltx
_G.dft_guide_cost_per_km = 4500 -- RU per km at cost multiplier 1.0
_G.dft_guide_costs = nil -- lazy-loaded from guide_danger.ltx on first use, see below

-- gamedata/configs/scripts/dorn_fast_travel/guide_danger.ltx - values tuned from Fair Fast
-- Travel's own [map_hazard_coefs] table since that's the best available reference for "how
-- dangerous is this level", but kept as our own standalone ltx (easy to inspect/rebalance)
-- rather than read from FFT at runtime, so this mod has zero dependency on FFT being installed.
dft_load_level_danger = function()
    local danger = {}
    local ini = ini_file("scripts\\dorn_fast_travel\\guide_danger.ltx")
    if ini and ini:section_exist("dft_guide_costs") then
        local ok_n, n = pcall(function() return ini:line_count("dft_guide_costs") end)
        if ok_n and n and n > 0 then
            for i = 0, n - 1 do
                local ok_line, found, key, val = pcall(function() return ini:r_line("dft_guide_costs", i, "", "") end)
                if ok_line and found and key then
                    danger[key] = tonumber(val)
                end
            end
        end
    end
    if not next(danger) then
        dft_log_error("guide_danger.ltx missing/empty - guide fee will default to cost multiplier 1.3 everywhere")
    end
    return danger
end

function dft_get_level_danger(level_name)
    if not _G.dft_guide_costs then
        _G.dft_guide_costs = dft_load_level_danger()
    end
    return (level_name and _G.dft_guide_costs[level_name]) or dft_guide_danger_mid
end

-- Some third-party mods (e.g. Milspec PDA) read game_fast_travel.trip_in_progress to avoid
-- misreading our journey's game-time jumps as elapsed real time (e.g. faction-access decay
-- timers). We mirror our own travel state into that flag so those mods behave correctly whether
-- or not Fair Fast Travel itself is installed - this never reads from or calls into FFT, it just
-- writes a shared flag other mods may be watching.
function dft_set_fft_trip_in_progress(active)
    _G.game_fast_travel = _G.game_fast_travel or {}
    _G.game_fast_travel.trip_in_progress = active and true or false
end

-- In-game seconds since a fixed anchor point, persisted on the actor so it survives saves,
-- level changes, and quickloads alike. Used for the sneak cooldown. NOTE: this deliberately
-- does NOT use level.get_start_time() - that resets on every level change (and every save
-- reload), which silently corrupted the cooldown any time a sneak journey crossed a zone
-- boundary (i.e. almost always, since that's the whole point of fast travel). The anchor
-- itself is just the first game-time snapshot ever taken this save; only its absolute
-- distance to "now" matters, so it never needs to be recomputed once set.
function dft_time_elapsed()
    if not db.actor then return 0 end
    local anchor_fields = load_var(db.actor, dft_save_vars.time_anchor, nil)
    local ok, secs = pcall(function()
        local now = game.get_game_time()
        local anchor = now
        if anchor_fields then
            anchor = game.CTime()
            anchor:set(anchor_fields.Y, anchor_fields.M, anchor_fields.D,
                anchor_fields.h, anchor_fields.m, anchor_fields.s, anchor_fields.ms)
        else
            local Y, M, D, h, m, s, ms = now:get(0, 0, 0, 0, 0, 0, 0)
            save_var(db.actor, dft_save_vars.time_anchor, { Y = Y, M = M, D = D, h = h, m = m, s = s, ms = ms })
        end
        return now:diffSec(anchor)
    end)
    return ok and math.floor(secs) or 0
end

