-- Dorn's Fast Travel: Safe positions, hostiles, road graph cache, path preview, journey dots.
-- Loaded automatically before zzzz_dorn_fast_travel_main.script

-- Shared dft globals (Anomaly isolates zzz_* script environments)
local dft = _G.dft
local dft_config = _G.dft_config

-- Forward declarations for this file's private (non-exported) helpers, so they can
-- reference each other regardless of definition order below.
local ambush_ground_snap, astar_navmesh_path, build_line_snap_path, build_navmesh_path, build_path_preview, build_preview_markers, clear_path_preview, densify_polyline, enforce_ambush_standoff, ensure_graph_spatial_index, finalize_ambush_landing, get_cached_line_snap_path, graph_near_road_fast, has_nearby_hostiles_at, horizontal_dist, is_pos_safe_from_anomalies, lvid_accessible, lvid_ground_pos, mesh_line_reachable, mesh_step, nearest_dot_index_for_ratio, nearest_hostile_world, nearest_road_node_fast, nearest_accessible_nav_vertex, path_preview_enabled, path_stats_for_target, place_ambush_landing, polyline_length, polyline_pos_at_ratio, ray_snap_ground_pos, smooth_navmesh_chain, squad_community_hostile, valid_lvid
local function lerp_pos(p1, p2, ratio, out)
    if not (p1 and p2 and out) then return end
    out:set(
        p1.x + (p2.x - p1.x) * ratio,
        p1.y + (p2.y - p1.y) * ratio,
        p1.z + (p2.z - p1.z) * ratio
    )
    return out
end

is_pos_safe_from_anomalies = function(pos, radius)
    if not (pos and db.storage and level) then return true end
    radius = radius or 4.5
    local r_sq = radius * radius
    for id, _ in pairs(db.storage) do
        if not level then return end
        local obj = level.object_by_id(id)
        if obj and IsAnomaly(obj) then
            if obj:position():distance_to_sqr(pos) < r_sq then
                return false
            end
        end
    end
    return true
end

lvid_ground_pos = function(lvid)
    if not (valid_lvid(lvid) and level and level.vertex_position) then return nil, nil end
    if not lvid_accessible(lvid) then return nil, nil end
    local ok, snapped = pcall(function() return level.vertex_position(lvid) end)
    if not (ok and snapped and snapped.x) then return nil, nil end
    local candidate = vector():set(snapped.x, snapped.y + 0.15, snapped.z)
    if not is_pos_safe_from_anomalies(candidate, 4.5) then return nil, nil end
    return candidate, lvid
end

local DFT_RAY_DOWN = vector():set(0, -1, 0)

-- Cast straight down from (x, origin_y, z); returns world Y of first static/obstacle hit.
local function raycast_down_y(x, origin_y, z, range)
    if not (ray_pick and rq_target and x and origin_y and z and range and range > 0) then
        return nil
    end
    local flags = bit.bor(rq_target.rqtStatic or 2, rq_target.rqtObstacle or 8)
    local origin = vector():set(x, origin_y, z)
    local ok, dist = pcall(function()
        local pick = ray_pick(origin, DFT_RAY_DOWN, range, flags, nil)
        if not pick then return nil end
        pick:query()
        local d = pick:get_distance()
        if not d or d <= 0.05 or d >= range * 0.999 then return nil end
        return d
    end)
    if not ok or not dist then return nil end
    return origin_y - dist
end

-- Head-height ray first, then a high fallback ray. Returns feet position + optional lvid.
ray_snap_ground_pos = function(pos, opts)
    opts = opts or {}
    if not (pos and pos.x and pos.z) then return nil, nil end
    local anchor = opts.anchor or pos
    local max_drift_m = opts.max_drift_m
    local ref_y = pos.y or anchor.y or 0
    local x, z = pos.x, pos.z

    local head_h = opts.head_m or 1.0
    local high_h = opts.high_m or 100.0
    local head_range = opts.head_range_m or 100.0
    local high_range = opts.high_range_m or 100.0

    local ground_y = raycast_down_y(x, ref_y + head_h, z, head_range)
    local ray_tag = "head"
    if not ground_y then
        ground_y = raycast_down_y(x, ref_y + high_h, z, high_range)
        ray_tag = "high"
    end
    if not ground_y then return nil, nil end

    local result = vector():set(x, ground_y + 0.15, z)
    if not is_pos_safe_from_anomalies(result, 4.5) then return nil, nil end

    if anchor and max_drift_m then
        local drift = horizontal_dist(result, anchor)
        if drift and drift > max_drift_m then
            dft_log("ray snap drift %.0fm > %.0fm (%s ray) - rejected", drift, max_drift_m, ray_tag)
            return nil, nil
        end
    end

    local lvid = nil
    if level and level.vertex_id then
        local ok, v = pcall(function() return level.vertex_id(result) end)
        if ok and valid_lvid(v) then lvid = v end
    end
    dft_log("ray snap (%s): ground Y=%.1f at (%.1f, %.1f, %.1f)", ray_tag, ground_y, x, result.y, z)
    return result, lvid
end

-- Snap a world position onto the level navmesh (ground). Optional lvid/gvid hints from target resolution.
-- opts.anchor + opts.max_drift_m: reject snaps that teleport far from the intended point (bad navmesh islands).
local function find_ground_pos(pos, lvid, gvid, opts)
    opts = opts or {}
    local anchor = opts.anchor or pos
    local max_drift_m = opts.max_drift_m

    local function finish(result_pos, result_lvid)
        if not (result_pos and anchor and max_drift_m) then
            return result_pos, result_lvid
        end
        local drift = (_G.dft_pos_drift and _G.dft_pos_drift(result_pos, anchor))
            or result_pos:distance_to(anchor)
        if drift > max_drift_m then
            dft_log("ground snap drift %.0fm > %.0fm at (%.0f, %.0f, %.0f) - keeping anchor",
                drift, max_drift_m, anchor.x, anchor.y, anchor.z)
            return vector():set(anchor.x, anchor.y, anchor.z), result_lvid
        end
        return result_pos, result_lvid
    end

    if not pos then
        if db and db.actor then return db.actor:position(), nil end
        return nil, nil
    end
    if not level then return finish(vector():set(pos.x, pos.y, pos.z), lvid) end

    if (opts.ray_first or opts.local_only) and ray_pick and rq_target then
        local ray_pos, ray_lvid = ray_snap_ground_pos(pos, opts)
        if ray_pos then return finish(ray_pos, ray_lvid or lvid) end
    end

    local function try_lvid(vid)
        return lvid_ground_pos(vid)
    end

    if lvid then
        local p, lv = try_lvid(lvid)
        if p then return finish(p, lv) end
    end

    if gvid then
        local graph = dft_graph_vertex_target(gvid)
        if graph and graph.lvid then
            local p, lv = try_lvid(graph.lvid)
            if p then return finish(p, lv) end
        end
    end

    local ok_vid, vid = pcall(function() return level.vertex_id(pos) end)
    if ok_vid and valid_lvid(vid) then
        local p, lv = try_lvid(vid)
        if p then return finish(p, lv) end
    end

    if max_drift_m and opts.local_only then
        local ref_y = anchor and anchor.y or pos.y
        local test = vector():set(pos.x, ref_y, pos.z)
        local radius = math.min(max_drift_m, 15)
        local y_steps = { ref_y, ref_y + 0.5, ref_y - 0.5, ref_y + 1.0, ref_y - 1.0 }
        for yi = 1, #y_steps do
            local y = y_steps[yi]
            for dx = -radius, radius, 2 do
                for dz = -radius, radius, 2 do
                    if (dx * dx + dz * dz) <= radius * radius then
                        test:set(pos.x + dx, y, pos.z + dz)
                        local ok, v = pcall(function() return level.vertex_id(test) end)
                        if ok and valid_lvid(v) then
                            local p, lv = try_lvid(v)
                            if p then return finish(p, lv) end
                        end
                    end
                end
            end
        end
        return finish(vector():set(anchor.x, anchor.y, anchor.z), lvid)
    end

    local ref_y = pos.y
    if db and db.actor and db.actor.position then
        local ok_ap, ap = pcall(function() return db.actor:position() end)
        if ok_ap and ap and ap.y then
            ref_y = (pos.y + ap.y) * 0.5
        end
    end

    local test = vector():set(pos.x, ref_y, pos.z)
    local y_steps = {}
    for i = 0, 16 do y_steps[#y_steps + 1] = ref_y + i * 0.5 end
    for i = 1, 12 do y_steps[#y_steps + 1] = ref_y - i * 0.5 end

    local xz_offsets = {
        {0, 0}, {1, 0}, {-1, 0}, {0, 1}, {0, -1},
        {2, 0}, {-2, 0}, {0, 2}, {0, -2},
        {1.5, 1.5}, {-1.5, 1.5}, {1.5, -1.5}, {-1.5, -1.5},
    }

    for _, y in ipairs(y_steps) do
        for o = 1, #xz_offsets do
            local dx, dz = xz_offsets[o][1], xz_offsets[o][2]
            test:set(pos.x + dx, y, pos.z + dz)
            local ok, v = pcall(function() return level.vertex_id(test) end)
            if ok and valid_lvid(v) then
                local p, lv = try_lvid(v)
                if p then return finish(p, lv) end
            end
        end
    end

    local near_max = (_G.dft_path and _G.dft_path.graph_nearest_max_m) or 50
    if not max_drift_m then
        local near_gvid = gvid
        if not near_gvid and graph_nearest_gvid then
            near_gvid = graph_nearest_gvid(pos, near_max)
        end
        if near_gvid then
            local graph = dft_graph_vertex_target(near_gvid)
            if graph and graph.lvid then
                local p, lv = try_lvid(graph.lvid)
                if p then return finish(p, lv) end
            end
        end
    end

    if ray_pick and rq_target then
        local ray_pos, ray_lvid = ray_snap_ground_pos(pos, {
            anchor = anchor,
            max_drift_m = max_drift_m,
        })
        if ray_pos then
            dft_log("ground snap: ray fallback at (%.1f, %.1f, %.1f)", ray_pos.x, ray_pos.y, ray_pos.z)
            return finish(ray_pos, ray_lvid or lvid)
        end
    end

    dft_log("WARN: ground snap failed at (%.1f, %.1f, %.1f) - keeping anchor", pos.x, pos.y, pos.z)
    return finish(vector():set(anchor.x, anchor.y, anchor.z), lvid)
end

local function get_safe_pos(pos, lvid, gvid)
    local p = find_ground_pos(pos, lvid, gvid)
    return p or (pos and vector():set(pos.x, pos.y + 1.5, pos.z) or db.actor:position())
end

local function apply_travel_offset(pos, offset_m)
    if not (pos and offset_m and offset_m > 0 and dft.start_pos and dft.dest_pos) then
        if offset_m and offset_m > 0 then
            dft_log("Travel offset skipped: missing start/dest (offset=%dm).", math.floor(offset_m + 0.5))
        end
        return pos
    end
    local dir = vector():set(dft.dest_pos.x - dft.start_pos.x, 0, dft.dest_pos.z - dft.start_pos.z)
    local dir_len = math.sqrt(dir.x * dir.x + dir.z * dir.z)
    if dir_len < 0.1 then
        dft_log("Travel offset skipped: start/dest too close (offset=%dm).", math.floor(offset_m + 0.5))
        return pos
    end
    dir:normalize()
    local along = (pos.x - dft.start_pos.x) * dir.x + (pos.z - dft.start_pos.z) * dir.z
    local pullback = math.min(offset_m, math.max(along, 0))
    if pullback < 0.1 then
        dft_log("Travel offset skipped: along-path %.1fm (offset=%dm).", along, math.floor(offset_m + 0.5))
        return pos
    end
    local offset_pos = vector():set(pos.x - dir.x * pullback, pos.y, pos.z - dir.z * pullback)
    local snapped, slv = find_ground_pos(offset_pos, nil, nil, {
        anchor = offset_pos,
        max_drift_m = 15,
        local_only = true,
        ray_first = true,
    })
    local result = snapped or offset_pos
    local short_m = horizontal_dist(result, pos) or result:distance_to(pos)
    dft_log("Travel offset: want=%dm pullback=%.0fm along=%.0fm short_of_dest=%.0fm pos=(%.1f,%.1f,%.1f)",
        math.floor(offset_m + 0.5), pullback, along, short_m or 0, result.x, result.y, result.z)
    return result
end

squad_community_hostile = function(community)
    if not community then return false end
    if community == "monster" or community == "zombied" or community == "monolith" then
        return true
    end
    if not (db.actor and relation_registry) then return false end
    local rel = relation_registry.community_relation(community, db.actor:character_community())
    return rel and rel < 0
end

local function collect_hostiles_at(pos, radius, level_id)
    local out = { squads = {}, npcs = {} }
    if not (pos and db.actor) then return out end
    radius = radius or dft_hostile.radius_m

    local gg = game_graph()
    local check_lid = level_id
    if not check_lid and gg then
        local ok_lid, res_lid = pcall(function() return gg:vertex(db.actor:game_vertex_id()):level_id() end)
        if ok_lid then check_lid = res_lid end
    end

    local squad_seen = {}
    local board = SIMBOARD
    if board and board.squads and check_lid and check_lid >= 0 and gg then
        pcall(function()
            for id, _ in pairs(board.squads) do
                if not squad_seen[id] then
                    local squad = alife_object(id)
                    if squad and (type(squad) == "userdata") and squad.position then
                        local squad_lid = -1
                        local ok_sl, res_sl = pcall(function() return gg:vertex(squad.m_game_vertex_id):level_id() end)
                        if ok_sl then squad_lid = res_sl end
                        if squad_lid == check_lid then
                            if dft_hostile_near_pos(pos, squad.position, radius) then
                                local community = "none"
                                local ok_comm, res_comm = pcall(function() return squad:get_squad_community() end)
                                if ok_comm then community = res_comm end
                                if squad_community_hostile(community) then
                                    squad_seen[id] = true
                                    out.squads[#out.squads + 1] = id
                                end
                            end
                        end
                    end
                end
            end
        end)
    end

    local npc_seen = {}
    if db.storage then
        for id, _ in pairs(db.storage) do
            if not npc_seen[id] then
                local npc = level.object_by_id(id)
                if npc and npc:id() ~= db.actor:id() then
                    local is_creature = false
                    pcall(function()
                        is_creature = IsStalker(npc) or IsMonster(npc)
                    end)
                    if is_creature then
                        local alive = false
                        local ok_alive, res_alive = pcall(function() return npc:alive() end)
                        alive = ok_alive and res_alive
                        if alive and dft_hostile_near_pos(pos, npc:position(), radius) then
                            local hostile = false
                            if IsMonster(npc) then
                                hostile = true
                            elseif IsStalker(npc) then
                                local ok_rel, rel = pcall(function() return npc:relation(db.actor) end)
                                if ok_rel and rel >= game_object.enemy then hostile = true end
                            end
                            if hostile then
                                npc_seen[id] = true
                                out.npcs[#out.npcs + 1] = id
                            end
                        end
                    end
                end
            end
        end
    end

    return out
end

-- True when static/obstacle geometry does not block from -> to (eye to chest height).
-- Used only for the outer ambush band; close band ignores LOS.
local function has_ambush_los(from_pos, to_pos)
    if not (from_pos and to_pos) then return false end
    if not (ray_pick and rq_target) then return true end
    local eye, chest = 1.55, 1.0
    local ox, oy, oz = from_pos.x, (from_pos.y or 0) + eye, from_pos.z
    local tx, ty, tz = to_pos.x, (to_pos.y or 0) + chest, to_pos.z
    local dx, dy, dz = tx - ox, ty - oy, tz - oz
    local dist = math.sqrt(dx * dx + dy * dy + dz * dz)
    if dist < 1.0 then return true end
    local ux, uy, uz = dx / dist, dy / dist, dz / dist
    local range = dist * 0.96
    local flags = bit.bor(rq_target.rqtStatic or 2, rq_target.rqtObstacle or 8)
    local ok, clear = pcall(function()
        local pick = ray_pick(vector():set(ox, oy, oz), vector():set(ux, uy, uz), range, flags, nil)
        if not pick then return true end
        pick:query()
        local hit = pick:get_distance()
        if not hit or hit <= 0.05 then return true end
        return hit >= range * 0.98
    end)
    return ok and clear == true
end

local function filter_hostiles_los(from_pos, targets)
    local out = { squads = {}, npcs = {} }
    if not (from_pos and targets) then return out end
    for i = 1, #(targets.squads or {}) do
        local id = targets.squads[i]
        local squad = alife_object(id)
        if squad and squad.position and has_ambush_los(from_pos, squad.position) then
            out.squads[#out.squads + 1] = id
        end
    end
    for i = 1, #(targets.npcs or {}) do
        local id = targets.npcs[i]
        local npc = level.object_by_id(id)
        if npc then
            local ok, np = pcall(function() return npc:position() end)
            if ok and np and has_ambush_los(from_pos, np) then
                out.npcs[#out.npcs + 1] = id
            end
        end
    end
    return out
end

-- Close band first (no LOS). If empty, outer band with LOS required.
-- Returns targets, radius_m, kind ("close"|"los"), or nil,nil,nil when clear.
local function scan_ambush_targets(pos, sneaky, level_id)
    if not pos then return nil, nil, nil end
    local close_r = dft_ambush_close_radius_m(sneaky)
    local close_t = collect_hostiles_at(pos, close_r, level_id)
    if #close_t.squads > 0 or #close_t.npcs > 0 then
        return close_t, close_r, "close"
    end
    local los_r = dft_ambush_radius_m(sneaky)
    local big_t = collect_hostiles_at(pos, los_r, level_id)
    if #big_t.squads == 0 and #big_t.npcs == 0 then
        return nil, nil, nil
    end
    local los_t = filter_hostiles_los(pos, big_t)
    if #los_t.squads == 0 and #los_t.npcs == 0 then
        return nil, nil, nil
    end
    return los_t, los_r, "los"
end

has_nearby_hostiles_at = function(pos, radius, level_id)
    local targets = collect_hostiles_at(pos, radius, level_id)
    return #targets.squads > 0 or #targets.npcs > 0
end

-- Unlike collect_hostiles_at (faction/relation based - flags anyone hostile whether or not
-- they've noticed the actor), this checks actual awareness: is any online stalker/monster
-- within radius currently targeting the actor as its best_enemy()? That's the engine's own
-- combat-AI notion of "who this NPC is actively hunting right now", so it only fires for
-- enemies genuinely engaging the player, not just any hostile-faction NPC standing nearby.
local function alerted_enemy_within(pos, radius)
    if not (pos and db.actor and db.storage) then return false end
    radius = radius or dft_hostile.radius_m
    local actor_id = db.actor:id()
    local best_dist, best_id = nil, nil
    for id, _ in pairs(db.storage) do
        if id ~= actor_id then
            local npc = level.object_by_id(id)
            if npc then
                local is_creature = false
                pcall(function() is_creature = IsStalker(npc) or IsMonster(npc) end)
                if is_creature then
                    local ok_alive, alive = pcall(function() return npc:alive() end)
                    if ok_alive and alive then
                        local ok_p, np = pcall(function() return npc:position() end)
                        if ok_p and np then
                            local d = horizontal_dist(pos, np) or pos:distance_to(np)
                            if d and d <= radius and (not best_dist or d < best_dist) then
                                local ok_e, enemy = pcall(function() return npc:best_enemy() end)
                                if ok_e and enemy then
                                    local ok_id, eid = pcall(function() return enemy:id() end)
                                    if ok_id and eid == actor_id then
                                        best_dist = d
                                        best_id = id
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return best_id ~= nil, best_dist, best_id
end

-- Positions of every transition trigger (native level changer or scripted sr_level_changer
-- restrictor) leading out of the current level, from the door registry already built by
-- dft_build_dynamic_map (02_zones). Cached per level for nearest-door lookups.
local function rebuild_door_position_cache(lvl_name)
    local cache = {}
    local id_cache = {}
    local dsts = dft.door_registry and dft.door_registry[lvl_name]
    if dsts then
        for _, ids in pairs(dsts) do
            for i = 1, #ids do
                local obj_id = ids[i]
                local pos = nil
                local se_obj = alife_object(obj_id)
                if se_obj and se_obj.position then pos = se_obj.position end
                if not pos then
                    local online = level.object_by_id(obj_id)
                    if online then
                        local ok, p = pcall(function() return online:position() end)
                        if ok then pos = p end
                    end
                end
                if pos then
                    cache[#cache + 1] = vector():set(pos.x, pos.y, pos.z)
                    id_cache[#id_cache + 1] = obj_id
                end
            end
        end
    end
    dft.door_pos_cache = cache
    dft.door_id_cache = id_cache
    dft.door_pos_cache_level = lvl_name
end

-- Nearest transition door id to pos within max_m (from door_registry on current level).
local function nearest_transition_door_id(pos, max_m)
    if not pos then return nil, nil end
    local lvl_name = dft_resolve_level_name(dft_actor_level_id())
    if dft.door_pos_cache_level ~= lvl_name then
        rebuild_door_position_cache(lvl_name)
    end
    local cache = dft.door_pos_cache or {}
    local ids = dft.door_id_cache or {}
    local best_d, best_id = nil, nil
    for i = 1, #cache do
        local d = horizontal_dist(pos, cache[i]) or pos:distance_to(cache[i])
        if (not max_m or d <= max_m) and (not best_d or d < best_d) then
            best_d = d
            best_id = ids[i]
        end
    end
    return best_id, best_d
end

local function is_registry_transition_door(door_id)
    if not door_id then return false end
    for _, dsts in pairs(dft.door_registry or {}) do
        for _, ids in pairs(dsts) do
            for i = 1, #ids do
                if ids[i] == door_id then return true end
            end
        end
    end
    return false
end

-- When the PDA picks the wrong map spot (companion icon over transition geography), redirect
-- to the nearest transition door if the click is clearly closer to it than to the spot object.
local function resolve_menu_spot_from_click(id, ln, click_pos, se_obj)
    if not (click_pos and click_pos.x and ln) then return id, ln end
    if dft_is_travel_destination(id) then return id, ln end

    local near_m = dft_path.menu_click_transition_near_m or 120
    local door_id, door_dist = nearest_transition_door_id(click_pos, near_m)
    if not door_id then return id, ln end

    local door_se = alife_object(door_id)
    if not (dft_is_pda_transition(door_id, door_se) or is_registry_transition_door(door_id)) then
        return id, ln
    end

    local obj_pos = se_obj and dft_object_position(se_obj, id)
    local click_off = obj_pos and (horizontal_dist(click_pos, obj_pos) or click_pos:distance_to(obj_pos))
    local min_off = dft_path.menu_click_redirect_off_m or 60
    if click_off and click_off < min_off then return id, ln end
    if door_dist and click_off and door_dist < click_off then
        dft_log("menu: click redirect id=%s -> door=%s (transition %.0fm vs spot %.0fm from click)",
            tostring(id), tostring(door_id), door_dist, click_off)
        return door_id, ln
    end
    return id, ln
end

-- Nearest transition-trigger position to pos within max_m, or nil if none registered/in range.
local function nearest_transition_point(pos, max_m)
    if not pos then return nil, nil end
    local lvl_name = dft_resolve_level_name(dft_actor_level_id())
    if dft.door_pos_cache_level ~= lvl_name then
        rebuild_door_position_cache(lvl_name)
    end
    local cache = dft.door_pos_cache or {}
    local best_d, best_pos = nil, nil
    for i = 1, #cache do
        local d = horizontal_dist(pos, cache[i]) or pos:distance_to(cache[i])
        if (not max_m or d <= max_m) and (not best_d or d < best_d) then
            best_d = d
            best_pos = cache[i]
        end
    end
    return best_pos, best_d
end

-- Native, engine-level hard block for every transition trigger leading out of the current
-- level. CLevelChanger (the C++ object behind every real "level_changer" spawn) exposes
-- enable_level_changer(bool) straight from Lua: when disabled, feel_touch_new's own check
-- (`if (m_b_enabled)`) makes touching it a complete no-op for silent transitions, and for
-- confirmation-dialog ones the engine passes the disabled flag through to the change-level
-- UI itself. This is the same toggle "Areas transition without confirmation"-style mods use
-- to manipulate level changers from script - not a position clamp, so it works identically
-- no matter where the player is standing, how they got there (on foot or teleported in by a
-- fast-travel arrival), or what the surrounding terrain looks like. Silently no-ops (via the
-- engine's own smart_cast guard) on any door_registry entry that isn't a real CLevelChanger
-- (e.g. some scripted/extra-transition restrictors from other addons), which is a safe
-- fallback - it just means the tiny minority of non-native transitions aren't hard-blocked.
local function set_current_level_changers_locked(locked)
    local lvl_name = dft_resolve_level_name(dft_actor_level_id())
    local dsts = lvl_name and dft.door_registry and dft.door_registry[lvl_name]
    local stats = { locked = locked, level = lvl_name, total = 0, online = 0, offline = 0, applied = 0, noop = 0 }
    if not dsts then
        dft._transition_lock_stats = stats
        return stats
    end
    for _, ids in pairs(dsts) do
        for i = 1, #ids do
            stats.total = stats.total + 1
            local obj = level.object_by_id(ids[i])
            if obj then
                stats.online = stats.online + 1
                local ok = pcall(function() obj:enable_level_changer(not locked) end)
                if ok then stats.applied = stats.applied + 1 else stats.noop = stats.noop + 1 end
            else
                stats.offline = stats.offline + 1
            end
        end
    end
    dft._transition_lock_stats = stats
    return stats
end

nearest_hostile_world = function(targets, near_pos)
    if not targets then return nil, nil end
    local best_d, nearest = nil, nil
    for i = 1, #(targets.squads or {}) do
        local squad = alife_object(targets.squads[i])
        if squad and squad.position then
            local sp = squad.position
            local d = near_pos and (horizontal_dist(near_pos, sp) or near_pos:distance_to(sp)) or 0
            if not best_d or d < best_d then best_d = d; nearest = sp end
        end
    end
    for i = 1, #(targets.npcs or {}) do
        local npc = level.object_by_id(targets.npcs[i])
        if npc then
            local ok, np = pcall(function() return npc:position() end)
            if ok and np then
                local d = near_pos and (horizontal_dist(near_pos, np) or near_pos:distance_to(np)) or 0
                if not best_d or d < best_d then best_d = d; nearest = np end
            end
        end
    end
    return nearest, best_d
end

local function nearest_hostile_dist_m(pos, targets)
    if not (pos and targets) then return nil end
    local best = nil
    for i = 1, #(targets.squads or {}) do
        local squad = alife_object(targets.squads[i])
        if squad and squad.position then
            local d = horizontal_dist(pos, squad.position) or pos:distance_to(squad.position)
            if d and (not best or d < best) then best = d end
        end
    end
    for i = 1, #(targets.npcs or {}) do
        local npc = level.object_by_id(targets.npcs[i])
        if npc then
            local ok, np = pcall(function() return npc:position() end)
            if ok and np then
                local d = horizontal_dist(pos, np) or pos:distance_to(np)
                if d and (not best or d < best) then best = d end
            end
        end
    end
    return best and math.floor(best + 0.5) or nil
end

-- Place ambush landing standoff_m from the nearest hostile, on the approach side (toward dest/start).
place_ambush_landing = function(anchor_pos, targets, standoff_m, approach_pos)
    if not (anchor_pos and targets and standoff_m and standoff_m > 0) then
        return anchor_pos
    end
    local hostile_pos = nearest_hostile_world(targets, anchor_pos)
    if not hostile_pos then
        return anchor_pos
    end
    local ap = approach_pos or anchor_pos
    local dx = ap.x - hostile_pos.x
    local dz = ap.z - hostile_pos.z
    local horiz = math.sqrt(dx * dx + dz * dz)
    if horiz < 0.5 then
        dx = anchor_pos.x - hostile_pos.x
        dz = anchor_pos.z - hostile_pos.z
        horiz = math.sqrt(dx * dx + dz * dz)
    end
    if horiz < 0.5 then
        dx, dz, horiz = 1, 0, 1
    end
    local out = vector():set(
        hostile_pos.x + (dx / horiz) * standoff_m,
        anchor_pos.y,
        hostile_pos.z + (dz / horiz) * standoff_m
    )
    local cur_d = horizontal_dist(anchor_pos, hostile_pos) or anchor_pos:distance_to(hostile_pos)
    dft_log("Ambush landing: %.0fm from hostile (was %.0fm from anchor) -> (%.1f,%.1f,%.1f)",
        standoff_m, cur_d or -1, out.x, out.y, out.z)
    return out
end

finalize_ambush_landing = function(pos, targets, approach_pos, opts)
    opts = opts or {}
    if not (pos and targets) then return pos, opts.lvid end
    local amb = _G.dft_ambush or {}
    local standoff = opts.standoff_m or amb.standoff_min_m or 20
    local approach = approach_pos or pos
    local out = place_ambush_landing(pos, targets, standoff, approach)
    out = enforce_ambush_standoff(out, targets, standoff, approach)
    local lvid = opts.lvid
    if opts.snap ~= false then
        local snapped, lv = ambush_ground_snap(out, lvid)
        if snapped then
            out = snapped
            if lv then lvid = lv end
        end
        out = enforce_ambush_standoff(out, targets, standoff, approach)
    end
    return out, lvid
end

ambush_ground_snap = function(pos, lvid)
    return find_ground_pos(pos, nil, nil, {
        anchor = pos,
        max_drift_m = 12,
        local_only = true,
        ray_first = true,
    })
end

local function log_ambush_scan(label, scan_pos, radius, targets)
    if not (scan_pos and targets) then return end
    local ns = #(targets.squads or {})
    local nn = #(targets.npcs or {})
    dft_log("Ambush %s: radius=%dm scan=(%.1f,%.1f,%.1f) squads=%d npcs=%d",
        tostring(label), math.floor((radius or 0) + 0.5), scan_pos.x, scan_pos.y, scan_pos.z, ns, nn)
    for i = 1, ns do
        local squad = alife_object(targets.squads[i])
        if squad and squad.position then
            local d = horizontal_dist(scan_pos, squad.position) or scan_pos:distance_to(squad.position)
            dft_log("  squad id=%s dist=%.0fm pos=(%.1f,%.1f,%.1f)",
                tostring(targets.squads[i]), d or -1, squad.position.x, squad.position.y, squad.position.z)
        end
    end
    for i = 1, nn do
        local npc = level.object_by_id(targets.npcs[i])
        if npc then
            local ok, np = pcall(function() return npc:position() end)
            if ok and np then
                local d = horizontal_dist(scan_pos, np) or scan_pos:distance_to(np)
                local name = "?"
                pcall(function() name = npc:name() end)
                dft_log("  npc id=%s %s dist=%.0fm pos=(%.1f,%.1f,%.1f)",
                    tostring(targets.npcs[i]), name, d or -1, np.x, np.y, np.z)
            end
        end
    end
end

enforce_ambush_standoff = function(pos, targets, min_m, away_from)
    if not (pos and targets and min_m and min_m > 0) then return pos end
    local best_d, nearest = nil, nil
    for i = 1, #(targets.squads or {}) do
        local squad = alife_object(targets.squads[i])
        if squad and squad.position then
            local d = horizontal_dist(pos, squad.position) or pos:distance_to(squad.position)
            if d and (not best_d or d < best_d) then best_d = d; nearest = squad.position end
        end
    end
    for i = 1, #(targets.npcs or {}) do
        local npc = level.object_by_id(targets.npcs[i])
        if npc then
            local ok, np = pcall(function() return npc:position() end)
            if ok and np then
                local d = horizontal_dist(pos, np) or pos:distance_to(np)
                if d and (not best_d or d < best_d) then best_d = d; nearest = np end
            end
        end
    end
    if not (nearest and best_d and best_d < min_m) then
        return pos
    end
    local dx = pos.x - nearest.x
    local dz = pos.z - nearest.z
    local horiz = math.sqrt(dx * dx + dz * dz)
    if horiz < 0.5 and away_from then
        dx = pos.x - away_from.x
        dz = pos.z - away_from.z
        horiz = math.sqrt(dx * dx + dz * dz)
    end
    if horiz < 0.5 then
        dx, dz, horiz = 1, 0, 1
    end
    local need = (min_m - best_d) + 1.0
    local out = vector():set(pos.x + dx / horiz * need, pos.y, pos.z + dz / horiz * need)
    dft_log("Ambush standoff: nearest hostile %.0fm < min %dm - pushed %.0fm to (%.1f,%.1f,%.1f)",
        best_d, math.floor(min_m + 0.5), need, out.x, out.y, out.z)
    return out
end

local function wake_ambush_squad_online(squad_id)
    local squad = alife_object(squad_id)
    if not squad then return end
    pcall(function()
        if squad.online ~= true then
            squad.force_online = true
            if squad.check_online_status then squad:check_online_status() end
            if squad.can_switch_online and squad:can_switch_online() then
                squad:switch_online()
            end
        end
        if squad.update then squad:update() end
        dft_log("  squad id=%s brought online (was offline).", tostring(squad_id))
    end)
end

-- Force ambush hostiles to treat the actor as their combat target (not just a stray wound).
-- Mirrors tasks_skyfall / xr_combat_ignore hit-by-actor handling so best_enemy() stays on us
-- even when other NPCs are visible or the ping came from off-screen.
local function ping_ambush_npc(npc_id, actor)
    local npc = level.object_by_id(npc_id)
    if not (npc and npc:alive() and actor) then return false end
    local name = "?"
    local aid = actor:id()
    pcall(function()
        name = npc:name()
        if save_var then
            save_var(npc, "xr_combat_ignore_enabled", false)
        end
        local st = db.storage and db.storage[npc_id]
        if st then
            st.hitted_by = aid
            st.enemy_id = aid
            if st.combat then
                if st.combat.set_enemy then
                    st.combat:set_enemy(actor)
                else
                    st.combat.enemy_id = aid
                end
            end
        end
        if game_object and game_object.enemy and npc.set_relation then
            npc:set_relation(game_object.enemy, actor)
        end
        if npc.set_enemy then
            npc:set_enemy(actor)
        end
        if xr_combat_ignore and xr_combat_ignore.fighting_with_actor_npcs then
            xr_combat_ignore.fighting_with_actor_npcs[npc_id] = true
        end
        local h = hit()
        h.draftsman = actor
        h.type = hit.wound
        h.direction = vector():set(actor:position()):sub(npc:position())
        if IsStalker and IsStalker(npc) then
            h:bone("bip01_spine")
        end
        local power = (_G.dft_ambush and _G.dft_ambush.ping_hit_power) or 0.01
        h.power = power
        h.impulse = 0
        npc:hit(h)
        dft_log("  npc id=%s %s ambush-aggro (ping power=%.3f).", tostring(npc_id), name, power)
    end)
    return true
end

local function ping_ambush_squad(squad_id, actor)
    local squad = alife_object(squad_id)
    if not (squad and squad.squad_members and actor) then return 0 end
    local n = 0
    for k in squad:squad_members() do
        if ping_ambush_npc(k.id, actor) then
            n = n + 1
        end
    end
    return n
end

local function alert_ambushers(targets, opts)
    if not (targets and db.actor) then return end
    opts = opts or {}
    local actor = db.actor
    local squad_done = {}
    local npc_done = {}
    local squads_online = 0
    local npcs_aggro = 0

    local function wake_squad(sid)
        if squad_done[sid] then return end
        squad_done[sid] = true
        local squad = alife_object(sid)
        if squad and squad.online ~= true then
            wake_ambush_squad_online(sid)
            squads_online = squads_online + 1
        end
        if squad and squad.squad_members and save_var then
            for k in squad:squad_members() do
                local member = level.object_by_id(k.id)
                if member then
                    save_var(member, "xr_combat_ignore_enabled", false)
                end
            end
        end
        npcs_aggro = npcs_aggro + ping_ambush_squad(sid, actor)
        if squad and squad.squad_members then
            for k in squad:squad_members() do
                npc_done[k.id] = true
            end
        end
    end

    for i = 1, #(targets.squads or {}) do
        wake_squad(targets.squads[i])
    end
    for i = 1, #(targets.npcs or {}) do
        local nid = targets.npcs[i]
        local se_npc = alife_object(nid)
        if se_npc and se_npc.group_id and se_npc.group_id ~= 65535 then
            wake_squad(se_npc.group_id)
        end
        if not npc_done[nid] then
            if ping_ambush_npc(nid, actor) then
                npcs_aggro = npcs_aggro + 1
            end
            npc_done[nid] = true
        end
    end

    dft_log("Ambush aggro: %d squads brought online, %d NPCs targeted at actor.",
        squads_online, npcs_aggro)

    -- Squads may still be spawning in after switch_online; the post-teleport time jump can
    -- also reshuffle best_enemy() toward other visible hostiles - reassert a few times.
    if not opts.no_retry then
        local snap = { squads = {}, npcs = {} }
        for i = 1, #(targets.squads or {}) do snap.squads[i] = targets.squads[i] end
        for i = 1, #(targets.npcs or {}) do snap.npcs[i] = targets.npcs[i] end
        for _, delay in ipairs({ 0.3, 1.0 }) do
            CreateTimeEvent("dft", "ambush_aggro_" .. tostring(delay), delay, function()
                alert_ambushers(snap, { no_retry = true })
                return true
            end)
        end
    end
end

local function resolve_arrival_position()
    local pos = find_ground_pos(dft.dest_pos, dft.dest_lvid, dft.dest_gvid)
    local sneaky = dft.travel_mode == "sneaky"
    local gg = game_graph()
    local dest_lid = nil
    if gg and dft.dest_gvid then
        local ok, lid = pcall(function() return gg:vertex(dft.dest_gvid):level_id() end)
        if ok then dest_lid = lid end
    end

    local targets, radius, kind = scan_ambush_targets(pos, sneaky, dest_lid)
    if not targets then
        dft.arrival_ambush_targets = nil
        dft.ambush_kind = nil
        return pos, 0
    end

    log_ambush_scan("arrival-scan-" .. tostring(kind), pos, radius, targets)

    local chance = dft_calc_sneak_chance(sneaky)
    if sneaky and chance > 0 then
        local roll = math.random(1, 100)
        if roll <= chance then
            dft_log("Arrival dodge: slipped past hostiles (roll %d <= %d%%).", roll, chance)
            dft.encounters_avoided = (dft.encounters_avoided or 0) + 1
            dft.arrival_ambush_targets = nil
            dft.ambush_kind = nil
            return pos, 0
        end
        dft_log("Arrival ambush: dodge failed (roll %d > %d%%).", roll, chance)
    else
        dft_log("Arrival ambush: travel mode (no dodge).")
    end

    dft.ambush_kind = kind
    local approach = dft.start_pos or pos
    local path_dist = nearest_hostile_dist_m(pos, targets)
    local short_pos, snap_lvid
    if kind == "close" then
        -- Close contact: standoff from the group, but never closer than the path point was.
        short_pos, snap_lvid = finalize_ambush_landing(pos, targets, approach, { lvid = dft.dest_lvid })
        local out_dist = nearest_hostile_dist_m(short_pos, targets)
        if path_dist and out_dist and out_dist < path_dist then
            dft_log("Arrival ambush: standoff would close gap (%dm -> %dm) - keeping path point.",
                path_dist, out_dist)
            short_pos, snap_lvid = pos, dft.dest_lvid
        end
    else
        -- LOS / far: stay on the approach path; pull short of dest by encounter offset only.
        local offset = dft_get_encounter_offset()
        dft_log("Arrival ambush (los): path landing, encounter offset=%dm.", offset or 0)
        short_pos = apply_travel_offset(pos, offset)
        snap_lvid = dft.dest_lvid
    end
    dft.arrival_ambush_targets = targets
    dft.arrival_short_m = math.floor(horizontal_dist(short_pos, pos) or short_pos:distance_to(pos))
    local nearest = nearest_hostile_dist_m(short_pos, targets)
    dft_log("Arrival ambush landing: kind=%s short_of_dest=%dm nearest_hostile=%sm pos=(%.1f,%.1f,%.1f)",
        tostring(kind), dft.arrival_short_m, nearest and tostring(nearest) or "?",
        short_pos.x, short_pos.y, short_pos.z)
    return short_pos, 1
end

local function resolve_lvid_for_pos(pos, lvid, gvid)
    if valid_lvid(lvid) then return lvid end
    if pos and level and level.vertex_id then
        local ok, lv = pcall(function() return level.vertex_id(pos) end)
        if ok and valid_lvid(lv) then return lv end
    end
    if gvid then
        local graph = dft_graph_vertex_target(gvid)
        if graph and graph.lvid then return graph.lvid end
    end
    return nil
end

valid_lvid = function(lvid)
    return lvid and lvid ~= dft_invalid_lvid and lvid ~= -1
end

horizontal_dist = function(a, b)
    if not (a and b) then return nil end
    local dx = a.x - b.x
    local dz = a.z - b.z
    return math.sqrt(dx * dx + dz * dz)
end

lvid_accessible = function(lvid)
    if not valid_lvid(lvid) then return false end
    if level.is_accessible_vertex_id then
        local ok, acc = pcall(function() return level.is_accessible_vertex_id(lvid) end)
        if ok and not acc then return false end
    end
    return true
end

polyline_length = function(chain)
    local path_len = 0
    for i = 1, #chain - 1 do
        path_len = path_len + (dft_distance_pda(chain[i], chain[i + 1]) or chain[i]:distance_to(chain[i + 1]))
    end
    return path_len
end

-- Higher score = better snap. Favors game-graph (road) vertices while penalizing distance from sample.
-- Anomaly exposes no gg:nearest_vertex or level.vertex_game_vertex_id in Lua - build a per-level cache.
ensure_level_graph_cache = function()
    local lvl_id = dft_actor_level_id()
    local lvl_name = (level and level.name) and level.name() or nil
    if dft.graph_cache and dft.graph_cache_level == lvl_id and dft.graph_cache_name == lvl_name then
        return
    end

    dft.graph_cache = {}
    dft.graph_lvid_map = {}
    dft.graph_cache_level = lvl_id
    dft.graph_cache_name = lvl_name

    if not (lvl_id and game_graph) then return end
    local gg = game_graph()
    if not (gg and gg.valid_vertex_id and gg.vertex) then return end

    local count = 0
    for gvid = 0, 65534 do
        if gg:valid_vertex_id(gvid) then
            local ok, gv = pcall(function() return gg:vertex(gvid) end)
            if ok and gv then
                local ok_l, lid = pcall(function() return gv:level_id() end)
                if ok_l and lid == lvl_id then
                    local ok_p, gpos = pcall(function() return gv:level_point() end)
                    local ok_lv, lvid = pcall(function() return gv:level_vertex_id() end)
                    if ok_p and gpos and gpos.x and ok_lv and lvid and lvid ~= dft_invalid_lvid then
                        local node = {
                            gvid = gvid,
                            lvid = lvid,
                            pos = vector():set(gpos.x, gpos.y, gpos.z),
                        }
                        dft.graph_cache[#dft.graph_cache + 1] = node
                        dft.graph_lvid_map[lvid] = gvid
                        count = count + 1
                    end
                end
            end
        end
    end

    dft_path_road_log(
        "graph cache built: %d nodes level_id=%s (%s)",
        count, tostring(lvl_id), tostring(lvl_name)
    )
end

graph_nearest_gvid = function(pos, max_m)
    if not pos then return nil end
    ensure_level_graph_cache()
    max_m = max_m or 999999
    local best_gvid, best_off = nil, max_m + 1
    for i = 1, #(dft.graph_cache or {}) do
        local node = dft.graph_cache[i]
        local off = horizontal_dist(pos, node.pos) or pos:distance_to(node.pos)
        if off < best_off then
            best_off = off
            best_gvid = node.gvid
        end
    end
    if best_gvid and best_off <= max_m then return best_gvid end
    return nil
end

graph_gvid_from_lvid = function(lvid)
    if not lvid or lvid == dft_invalid_lvid then return nil end
    ensure_level_graph_cache()
    return dft.graph_lvid_map and dft.graph_lvid_map[lvid]
end

-- Spatial hash over dft.graph_cache so "is this point near a road" is O(1)-ish instead of
-- an O(n) scan. Needed because astar_navmesh_path can call this thousands of times
-- (once per candidate direction per expanded node) - a linear scan there would hitch badly.
local DFT_GRAPH_GRID_CELL_M = 20

local function grid_key(gx, gz)
    return gx .. "_" .. gz
end

ensure_graph_spatial_index = function()
    ensure_level_graph_cache()
    if dft.graph_grid and dft.graph_grid_source == dft.graph_cache then
        return
    end
    local grid = {}
    for i = 1, #(dft.graph_cache or {}) do
        local node = dft.graph_cache[i]
        local key = grid_key(math.floor(node.pos.x / DFT_GRAPH_GRID_CELL_M), math.floor(node.pos.z / DFT_GRAPH_GRID_CELL_M))
        local bucket = grid[key]
        if not bucket then bucket = {}; grid[key] = bucket end
        bucket[#bucket + 1] = node
    end
    dft.graph_grid = grid
    dft.graph_grid_source = dft.graph_cache
end

-- Nearest cached road-graph node to pos within max_m, or nil. Shared by the "is on a road"
-- check and the A* road-seeking candidate step.
local function grid_query_nearest(grid, pos, max_m)
    if not (grid and pos and max_m) then return nil end
    local max_sq = max_m * max_m
    local cx = math.floor(pos.x / DFT_GRAPH_GRID_CELL_M)
    local cz = math.floor(pos.z / DFT_GRAPH_GRID_CELL_M)
    local radius_cells = math.max(1, math.ceil(max_m / DFT_GRAPH_GRID_CELL_M))
    local best, best_sq = nil, max_sq
    for gx = cx - radius_cells, cx + radius_cells do
        for gz = cz - radius_cells, cz + radius_cells do
            local bucket = grid[grid_key(gx, gz)]
            if bucket then
                for i = 1, #bucket do
                    local node = bucket[i]
                    local dx = node.pos.x - pos.x
                    local dz = node.pos.z - pos.z
                    local dsq = dx * dx + dz * dz
                    if dsq <= best_sq then
                        best_sq = dsq
                        best = node
                    end
                end
            end
        end
    end
    return best
end

graph_near_road_fast = function(pos, max_m)
    if not pos then return false end
    ensure_graph_spatial_index()
    max_m = max_m or dft_path.road_on_graph_max_m or 5
    return grid_query_nearest(dft.graph_grid, pos, max_m) ~= nil
end

nearest_road_node_fast = function(pos, max_m)
    if not pos then return nil end
    ensure_graph_spatial_index()
    max_m = max_m or dft_path.nav_road_seek_m or 45
    return grid_query_nearest(dft.graph_grid, pos, max_m)
end

-- ============================================================
-- Navmesh A* pathfinder
-- ============================================================
-- Anomaly's Lua API exposes no game_graph:shortest_path / verify_path / create_path.
-- The one reliable ground-truth primitive is level.vertex_in_direction(lvid, dir, dist):
-- the same mesh-constrained "walk" the engine's own AI danger/scatter planning uses
-- (see xr_danger.script position_node:select_best_vertex_id). It steps across the
-- navmesh triangulation in a given direction and stops at the mesh boundary, so it can
-- never cut through a wall, over a cliff edge, or into the void. We use it as the
-- fundamental "move" operator for a proper A* search: nodes are navmesh vertices,
-- edges are validated mesh-walk hops in a fan of directions around the bearing to goal.
-- The resulting path is reliable at every point in between - not just at fixed samples -
-- and is reused for the displayed path, ambush ratio->position lookups, and every
-- mid-journey teleport (encounter/emission interrupts, arrival landing).

local function atan2(y, x)
    if math.atan2 then return math.atan2(y, x) end
    if x > 0 then return math.atan(y / x) end
    if x < 0 and y >= 0 then return math.atan(y / x) + math.pi end
    if x < 0 and y < 0 then return math.atan(y / x) - math.pi end
    if x == 0 and y > 0 then return math.pi / 2 end
    if x == 0 and y < 0 then return -math.pi / 2 end
    return 0
end

-- Binary min-heap over lvid keys, ordered by nodes[lvid].f. Needed because A* on a
-- 1500-node search with a linear-scan open list would be O(n^2); the heap keeps it O(n log n).
local function heap_swap(heap, i, j)
    local a, b = heap.items[i], heap.items[j]
    heap.items[i], heap.items[j] = b, a
    heap.index[a] = j
    heap.index[b] = i
end

local function heap_sift_up(heap, nodes, i)
    while i > 1 do
        local parent = math.floor(i / 2)
        if nodes[heap.items[i]].f < nodes[heap.items[parent]].f then
            heap_swap(heap, i, parent)
            i = parent
        else
            break
        end
    end
end

local function heap_sift_down(heap, nodes, i)
    local n = #heap.items
    while true do
        local l, r, smallest = i * 2, i * 2 + 1, i
        if l <= n and nodes[heap.items[l]].f < nodes[heap.items[smallest]].f then smallest = l end
        if r <= n and nodes[heap.items[r]].f < nodes[heap.items[smallest]].f then smallest = r end
        if smallest == i then break end
        heap_swap(heap, i, smallest)
        i = smallest
    end
end

local function heap_push(heap, nodes, lvid)
    local n = #heap.items + 1
    heap.items[n] = lvid
    heap.index[lvid] = n
    heap_sift_up(heap, nodes, n)
end

local function heap_decrease(heap, nodes, lvid)
    local i = heap.index[lvid]
    if not i then heap_push(heap, nodes, lvid); return end
    heap_sift_up(heap, nodes, i)
end

local function heap_pop(heap, nodes)
    local n = #heap.items
    if n == 0 then return nil end
    local top = heap.items[1]
    local last = heap.items[n]
    heap.items[1] = last
    heap.index[last] = 1
    heap.items[n] = nil
    heap.index[top] = nil
    if n > 1 then heap_sift_down(heap, nodes, 1) end
    return top
end

-- A hop only counts as "genuinely blocked" if it moved almost nothing at all. Requiring a
-- fixed fraction of the *requested* distance (e.g. 35% of an 18m ask = 6.3m) throws away
-- perfectly real progress near walls/corners/doorways, where level.vertex_in_direction
-- legitimately stops a couple meters in because it hit geometry - not because that direction
-- is a dead end. Using whichever of (fraction, absolute floor) is smaller keeps small-but-real
-- moves near obstacles while still rejecting true zero-movement steps.
local function mesh_step_ok(moved, use_step, min_move_fr, min_move_abs)
    if not moved then return false end
    local threshold = use_step * (min_move_fr or 0.35)
    if min_move_abs and min_move_abs < threshold then threshold = min_move_abs end
    return moved >= threshold
end

-- Move dist_m from from_pos (at lvid) in direction (dir_x,dir_z), staying on navmesh.
-- Returns next_lvid, next_pos, actual_moved_m — or nil if blocked/invalid/inaccessible.
mesh_step = function(lvid, from_pos, dir_x, dir_z, dist_m)
    if not (level and level.vertex_in_direction and valid_lvid(lvid) and from_pos and dist_m and dist_m > 0) then
        return nil
    end
    local len = math.sqrt(dir_x * dir_x + dir_z * dir_z)
    if len < 0.001 then return nil end
    local dir = vector():set(dir_x / len, 0, dir_z / len)
    local ok, next_lvid = pcall(function() return level.vertex_in_direction(lvid, dir, dist_m) end)
    if not ok or not valid_lvid(next_lvid) or next_lvid == lvid then return nil end
    if not lvid_accessible(next_lvid) then return nil end
    local ok_p, pos = pcall(function() return level.vertex_position(next_lvid) end)
    if not (ok_p and pos and pos.x) then return nil end
    local next_pos = vector():set(pos.x, pos.y, pos.z)
    local moved = horizontal_dist(from_pos, next_pos) or from_pos:distance_to(next_pos)
    return next_lvid, next_pos, moved
end

-- Same as mesh_step, but retries at progressively shorter distances if the full-length
-- cast fails outright (level.vertex_in_direction can land back on the same vertex, or an
-- inaccessible one, when a long straight-line ask crosses a doorway/tight corner/short wall
-- segment that a shorter ask in the same direction would clear cleanly). Only falls back this
-- way when the long attempt found *nothing usable* - if it moved a little, mesh_step_ok's
-- absolute floor already accepts that without needing a retry.
local function mesh_step_adaptive(lvid, from_pos, dir_x, dir_z, dist_m, min_move_fr, min_move_abs)
    local next_lvid, next_pos, moved = mesh_step(lvid, from_pos, dir_x, dir_z, dist_m)
    if next_lvid and mesh_step_ok(moved, dist_m, min_move_fr, min_move_abs) then
        return next_lvid, next_pos, moved
    end
    local shrink = { 0.5, 0.25, 0.12 }
    for i = 1, #shrink do
        local d = dist_m * shrink[i]
        if d < 1.0 then break end
        local nl, np, mv = mesh_step(lvid, from_pos, dir_x, dir_z, d)
        if nl and mesh_step_ok(mv, d, min_move_fr, min_move_abs) then
            return nl, np, mv
        end
    end
    return nil
end

local function resolve_nav_vertex(pos, opts)
    opts = opts or {}
    local max_scan = opts.max_scan_m or 30
    if not (level and level.vertex_id and pos) then return nil end
    local ok, lvid = pcall(function() return level.vertex_id(pos) end)
    if ok and valid_lvid(lvid) and lvid_accessible(lvid) then return lvid, pos end
    local snapped = find_ground_pos(pos, nil, nil, {
        anchor = pos, max_drift_m = max_scan, local_only = true, ray_first = true,
    })
    if snapped then
        local ok2, lvid2 = pcall(function() return level.vertex_id(snapped) end)
        if ok2 and valid_lvid(lvid2) and lvid_accessible(lvid2) then return lvid2, snapped end
    end
    if opts.widen ~= false then
        return nearest_accessible_nav_vertex(pos, max_scan)
    end
    return nil
end

-- Expanding ring search for the nearest walkable navmesh vertex to pos. Transitions and
-- restrictors often sit off-mesh (water, door volumes); pathfinding needs a nearby target.
nearest_accessible_nav_vertex = function(pos, max_m)
    if not (pos and level and level.vertex_id and level.vertex_position) then return nil, nil end
    max_m = max_m or (dft_path.nav_goal_scan_max_m or 60)
    local best_lvid, best_dist, best_pos = nil, max_m + 1, nil

    local function consider(lvid)
        if not lvid_accessible(lvid) then return end
        local ok, vp = pcall(function() return level.vertex_position(lvid) end)
        if not (ok and vp and vp.x) then return end
        local d = horizontal_dist(pos, vp) or pos:distance_to(vp)
        if d < best_dist then
            best_dist = d
            best_lvid = lvid
            best_pos = vector():set(vp.x, vp.y, vp.z)
        end
    end

    local test = vector():set(pos.x, pos.y, pos.z)
    local y_steps = { 0, 0.5, -0.5, 1.0, -1.0, 1.5, -1.5 }
    for r = 0, max_m, 3 do
        if r == 0 then
            for yi = 1, #y_steps do
                test:set(pos.x, pos.y + y_steps[yi], pos.z)
                local ok, v = pcall(function() return level.vertex_id(test) end)
                if ok then consider(v) end
            end
        else
            local steps = math.max(12, math.floor(r * 1.5))
            for i = 0, steps - 1 do
                local ang = (2 * math.pi * i) / steps
                local dx, dz = math.cos(ang) * r, math.sin(ang) * r
                for yi = 1, #y_steps do
                    test:set(pos.x + dx, pos.y + y_steps[yi], pos.z + dz)
                    local ok, v = pcall(function() return level.vertex_id(test) end)
                    if ok then consider(v) end
                end
            end
        end
        if best_dist <= 3 then break end
    end

    ensure_level_graph_cache()
    for i = 1, #(dft.graph_cache or {}) do
        local node = dft.graph_cache[i]
        local d = horizontal_dist(pos, node.pos) or pos:distance_to(node.pos)
        if d <= max_m and d < best_dist and lvid_accessible(node.lvid) then
            best_dist = d
            best_lvid = node.lvid
            best_pos = vector():set(node.pos.x, node.pos.y, node.pos.z)
        end
    end

    if best_lvid then
        dft_path_road_log(
            "nav vertex scan: found lvid=%s %.0fm from (%.0f,%.0f,%.0f)",
            tostring(best_lvid), best_dist, pos.x, pos.y, pos.z
        )
    end
    return best_lvid, best_pos
end

-- Progressive ring scan for the nearest walkable navmesh anchor to a world point.
local function resolve_nav_anchor(world_pos, label)
    if not world_pos then return nil end
    local rings = dft_path.nav_anchor_scan_rings or { 20, 50, 100, 400 }
    for i = 1, #rings do
        local radius = rings[i]
        local lvid, pos = resolve_nav_vertex(world_pos, { max_scan_m = radius, widen = false })
        if not lvid then
            lvid, pos = nearest_accessible_nav_vertex(world_pos, radius)
        end
        if lvid and pos then
            local drift = horizontal_dist(world_pos, pos) or world_pos:distance_to(pos)
            dft_path_road_log(
                "nav anchor %s: ring=%dm drift=%.0fm lvid=%s",
                tostring(label or "?"), radius, drift, tostring(lvid)
            )
            return { lvid = lvid, pos = pos, drift_m = drift, scan_m = radius }
        end
    end
    return nil
end

-- Pick a wider dest anchor mesh-reachable from a path endpoint (one retry at finalize).
local function resolve_nav_anchor_reachable(world_pos, from_pos, min_scan_m)
    local rings = dft_path.nav_anchor_scan_rings or { 20, 50, 100, 400 }
    local connector_max = dft_path.nav_connector_max_m or 50
    local best = nil
    for i = 1, #rings do
        local radius = rings[i]
        if radius >= (min_scan_m or 0) then
            local lvid, pos = nearest_accessible_nav_vertex(world_pos, radius)
            if lvid and pos then
                local drift = horizontal_dist(world_pos, pos) or world_pos:distance_to(pos)
                local reach_d = horizontal_dist(from_pos, pos) or from_pos:distance_to(pos)
                if reach_d <= connector_max and mesh_line_reachable(from_pos, pos) then
                    if not best or drift < best.drift_m then
                        best = { lvid = lvid, pos = pos, drift_m = drift, scan_m = radius }
                    end
                end
            end
        end
    end
    if best then
        dft_path_road_log(
            "nav anchor retry: drift=%.0fm ring=%dm lvid=%s",
            best.drift_m, best.scan_m, tostring(best.lvid)
        )
    end
    return best
end

local function chain_copy_point(p)
    return vector():set(p.x, p.y, p.z)
end

local function reverse_nav_chain(chain)
    local out = {}
    for i = #chain, 1, -1 do
        out[#out + 1] = chain_copy_point(chain[i])
    end
    return out
end

local function chain_point_dist(a, b)
    if not (a and b) then return nil end
    return horizontal_dist(a, b) or a:distance_to(b)
end

local function sample_chain_indices(count, max_samples)
    max_samples = max_samples or (dft_path.nav_link_sample_max or 6)
    if count <= 0 then return {} end
    if count <= max_samples then
        local out = {}
        for i = 1, count do out[#out + 1] = i end
        return out
    end
    local out = { 1, count }
    local slots = max_samples - 2
    for k = 1, slots do
        local idx = math.floor(1 + k * (count - 1) / (slots + 1) + 0.5)
        if idx < 1 then idx = 1 elseif idx > count then idx = count end
        out[#out + 1] = idx
    end
    table.sort(out)
    local dedup = { out[1] }
    for i = 2, #out do
        if out[i] ~= dedup[#dedup] then dedup[#dedup + 1] = out[i] end
    end
    return dedup
end

local function reach_cache_key(a, b)
    return string.format(
        "%.1f_%.1f_%.1f|%.1f_%.1f_%.1f",
        a.x, a.y, a.z, b.x, b.y, b.z
    )
end

local function mesh_line_reachable_cached(cache, from_pos, to_pos)
    if not (from_pos and to_pos) then return false end
    local key = reach_cache_key(from_pos, to_pos)
    local rev_key = reach_cache_key(to_pos, from_pos)
    if cache[key] ~= nil then return cache[key] end
    if cache[rev_key] ~= nil then return cache[rev_key] end
    local ok = mesh_line_reachable(from_pos, to_pos)
    cache[key] = ok
    cache[rev_key] = ok
    return ok
end

local function build_linked_chain(fwd_chain, fi, rev_chain, ri, tag_no_land)
    local out = {}
    for i = 1, fi do
        out[#out + 1] = chain_copy_point(fwd_chain[i])
    end
    local no_land = nil
    local patch_from = #out
    local splice_d = chain_point_dist(out[#out], rev_chain[ri]) or 0
    if splice_d > 1.0 then
        out[#out + 1] = chain_copy_point(rev_chain[ri])
    end
    if tag_no_land and patch_from < #out then
        no_land = { from_idx = patch_from, to_idx = #out }
    end
    for i = ri - 1, 1, -1 do
        out[#out + 1] = chain_copy_point(rev_chain[i])
    end
    return out, no_land, splice_d
end

local function build_p3_patch_chain(fwd_chain, dest_pos)
    if not (fwd_chain and #fwd_chain >= 1 and dest_pos) then return nil, nil end
    local out = {}
    for i = 1, #fwd_chain do
        out[#out + 1] = chain_copy_point(fwd_chain[i])
    end
    local patch_from = #out
    out[#out + 1] = chain_copy_point(dest_pos)
    return out, { from_idx = patch_from, to_idx = #out }
end

local function collect_link_candidates(fwd_chain, rev_chain, world_dest, reach_cache)
    local candidates = {}
    local pair_count = 0
    local max_pairs = dft_path.nav_link_pair_max or 36
    local splice_max = dft_path.nav_link_splice_max_m or 72
    local mid_max = dft_path.nav_link_mid_max_m or 50
    local patch_max = dft_path.nav_connector_max_m or 50
    local sample_max = dft_path.nav_link_sample_max or 6

    local function try_pair(tier, kind, fi, ri, gap, tag_no_land, extra)
        if pair_count >= max_pairs then return end
        pair_count = pair_count + 1
        candidates[#candidates + 1] = {
            tier = tier, kind = kind, fi = fi, ri = ri, gap = gap,
            tag_no_land = tag_no_land, extra = extra,
        }
    end

    if fwd_chain and rev_chain and #fwd_chain >= 1 and #rev_chain >= 1 then
        local fwd_tail = sample_chain_indices(#fwd_chain, sample_max)
        local rev_head = sample_chain_indices(#rev_chain, sample_max)
        local rev_tail = sample_chain_indices(#rev_chain, sample_max)
        local fwd_head = sample_chain_indices(#fwd_chain, sample_max)

        for ti = 1, #fwd_tail do
            local fi = fwd_tail[ti]
            for hi = 1, #rev_head do
                local ri = rev_head[hi]
                local gap = chain_point_dist(fwd_chain[fi], rev_chain[ri])
                if gap and gap <= splice_max
                    and mesh_line_reachable_cached(reach_cache, fwd_chain[fi], rev_chain[ri]) then
                    try_pair(1, "splice_tail_head", fi, ri, gap, false, nil)
                end
            end
        end

        for hi = 1, #fwd_head do
            local fi = fwd_head[hi]
            for ti = 1, #rev_tail do
                local ri = rev_tail[ti]
                local gap = chain_point_dist(fwd_chain[fi], rev_chain[ri])
                if gap and gap <= splice_max
                    and mesh_line_reachable_cached(reach_cache, fwd_chain[fi], rev_chain[ri]) then
                    try_pair(1, "splice_cross", fi, ri, gap, false, nil)
                end
            end
        end

        local fwd_mid = sample_chain_indices(#fwd_chain, sample_max)
        local rev_mid = sample_chain_indices(#rev_chain, sample_max)
        for mi = 1, #fwd_mid do
            local fi = fwd_mid[mi]
            for mj = 1, #rev_mid do
                local ri = rev_mid[mj]
                local gap = chain_point_dist(fwd_chain[fi], rev_chain[ri])
                if gap and gap <= mid_max
                    and mesh_line_reachable_cached(reach_cache, fwd_chain[fi], rev_chain[ri]) then
                    try_pair(2, "mid_bridge", fi, ri, gap, true, nil)
                end
            end
        end

        local fi = #fwd_chain
        local ri = #rev_chain
        local gap = chain_point_dist(fwd_chain[fi], rev_chain[ri])
        if gap and gap <= patch_max
            and mesh_line_reachable_cached(reach_cache, fwd_chain[fi], rev_chain[ri]) then
            try_pair(3, "patch_p1", fi, ri, gap, true, nil)
        end
    end

    if fwd_chain and #fwd_chain >= 1 and world_dest then
        local fi = #fwd_chain
        local gap = chain_point_dist(fwd_chain[fi], world_dest)
        if gap and gap <= patch_max
            and mesh_line_reachable_cached(reach_cache, fwd_chain[fi], world_dest) then
            try_pair(4, "patch_p3", fi, nil, gap, true, world_dest)
        end
    end

    table.sort(candidates, function(a, b)
        if a.tier ~= b.tier then return a.tier < b.tier end
        return (a.gap or 1e9) < (b.gap or 1e9)
    end)
    return candidates
end

local function build_chain_from_candidate(cand, fwd_chain, rev_chain, world_dest)
    if cand.kind == "patch_p3" then
        return build_p3_patch_chain(fwd_chain, cand.extra or world_dest)
    end
    if not (fwd_chain and rev_chain and cand.fi and cand.ri) then return nil, nil end
    return build_linked_chain(fwd_chain, cand.fi, rev_chain, cand.ri, cand.tag_no_land)
end

local function find_best_linked_path(fwd_chain, rev_chain, world_dest, reach_cache)
    local candidates = collect_link_candidates(fwd_chain, rev_chain, world_dest, reach_cache)
    for i = 1, #candidates do
        local cand = candidates[i]
        local chain, no_land = build_chain_from_candidate(cand, fwd_chain, rev_chain, world_dest)
        if chain and #chain >= 2 then
            return chain, cand.kind, no_land, cand.gap
        end
    end

    if fwd_chain and rev_chain and #fwd_chain >= 1 and #rev_chain >= 1 then
        local fi = #fwd_chain
        local ri = #rev_chain
        local gap = chain_point_dist(fwd_chain[fi], rev_chain[ri])
        if gap and mesh_line_reachable_cached(reach_cache, fwd_chain[fi], rev_chain[ri]) then
            local chain, no_land = build_linked_chain(fwd_chain, fi, rev_chain, ri, true)
            if chain and #chain >= 2 then
                return chain, "patch_p4_forced", no_land, gap
            end
        end
    end
    return nil, nil, nil, nil
end

local function is_no_land_segment(seg, seg_idx)
    if not (seg and seg.from_idx and seg.to_idx) then return false end
    return seg_idx >= seg.from_idx and seg_idx < seg.to_idx
end

local function build_path_meta(chain, no_land_segments, mode)
    local safe_vertices = {}
    if not chain or #chain < 1 then
        return { safe_vertices = safe_vertices, no_land_segments = no_land_segments or {}, mode = mode }
    end
    safe_vertices[1] = 1
    for i = 2, #chain - 1 do
        local unsafe = false
        for s = 1, #(no_land_segments or {}) do
            if is_no_land_segment(no_land_segments[s], i) then
                unsafe = true
                break
            end
        end
        if not unsafe then safe_vertices[#safe_vertices + 1] = i end
    end
    safe_vertices[#safe_vertices + 1] = #chain
    return {
        safe_vertices = safe_vertices,
        no_land_segments = no_land_segments or {},
        mode = mode,
    }
end

local function apply_endpoint_connectors(chain, world_start, world_dest, start_anchor, dest_anchor, reach_cache)
    local connector_max = dft_path.nav_connector_max_m or 50
    local weak = { start = false, dest = false }
    if not (chain and #chain >= 1) then return weak end

    chain[1] = chain_copy_point(world_start)

    if start_anchor and start_anchor.drift_m and start_anchor.drift_m > 0.5 then
        if start_anchor.drift_m > connector_max then
            weak.start = true
        elseif not mesh_line_reachable_cached(reach_cache, world_start, start_anchor.pos) then
            weak.start = true
        else
            local next_pt = chain[2]
            if not next_pt or chain_point_dist(start_anchor.pos, next_pt) > 1.5 then
                table.insert(chain, 2, chain_copy_point(start_anchor.pos))
            end
        end
    end

    local last = chain[#chain]
    local dest_drift = chain_point_dist(last, world_dest) or 0
    if dest_drift > 0.5 then
        if dest_drift > connector_max then
            weak.dest = true
        elseif mesh_line_reachable_cached(reach_cache, last, world_dest) then
            chain[#chain + 1] = chain_copy_point(world_dest)
        else
            weak.dest = true
        end
    end
    return weak
end

-- Line-of-sight test on the navmesh: repeatedly mesh-step from from_pos toward to_pos and
-- check we actually arrive (used to validate polyline shortcuts during smoothing).
mesh_line_reachable = function(from_pos, to_pos, opts)
    opts = opts or {}
    if not (level and level.vertex_id and level.vertex_in_direction) then return false end
    local step_m = opts.step_m or dft_path.nav_smooth_step_m or 15
    local tol_m = opts.tol_m or dft_path.nav_smooth_tolerance_m or 3
    local min_move_fr = opts.min_move_frac or dft_path.nav_min_move_frac or 0.35
    local min_move_abs = opts.min_move_abs_m or dft_path.nav_min_move_abs_m or 1.2
    local dist = horizontal_dist(from_pos, to_pos) or from_pos:distance_to(to_pos)
    if dist <= tol_m then return true end
    local max_hops = opts.max_hops or math.min(160, math.ceil(dist / step_m) + 4)

    local lvid = resolve_nav_vertex(from_pos)
    if not lvid then return false end
    local cur_pos = vector():set(from_pos.x, from_pos.y, from_pos.z)

    for _ = 1, max_hops do
        local remain = horizontal_dist(cur_pos, to_pos) or cur_pos:distance_to(to_pos)
        if remain <= tol_m then return true end
        local dx = to_pos.x - cur_pos.x
        local dz = to_pos.z - cur_pos.z
        local use_step = math.min(step_m, remain)
        local next_lvid, next_pos, moved = mesh_step_adaptive(lvid, cur_pos, dx, dz, use_step, min_move_fr, min_move_abs)
        if not next_lvid then
            return false
        end
        lvid, cur_pos = next_lvid, next_pos
    end
    local remain = horizontal_dist(cur_pos, to_pos) or cur_pos:distance_to(to_pos)
    return remain <= tol_m
end

-- A* over the navmesh using mesh_step as the edge primitive. Nodes are keyed by lvid
-- (naturally de-duplicating nearby samples that snap to the same mesh vertex). Each node
-- expands along a fan of directions around the bearing to goal, so the search can route
-- around obstacles while still being biased toward direct progress. Cost is discounted
-- near cached game-graph (road) vertices so roads are favored without being required.
astar_navmesh_path = function(start_pos, dest_pos, opts)
    opts = opts or {}
    if not (level and level.vertex_in_direction and level.vertex_id and level.vertex_position) then
        return nil, false, 0, "no_vertex_in_direction"
    end
    if not (start_pos and dest_pos) then return nil, false, 0, "no_endpoints" end

    local step_m     = opts.step_m or dft_path.nav_step_m or 18
    local max_nodes  = opts.max_nodes or dft_path.nav_max_nodes or 1500
    local goal_tol   = opts.goal_tol_m or dft_path.nav_goal_tol_m or 12
    local road_mult  = opts.road_cost_mult or dft_path.nav_road_cost_mult or 0.55
    local min_move_fr = opts.min_move_frac or dft_path.nav_min_move_frac or 0.35
    local min_move_abs = opts.min_move_abs_m or dft_path.nav_min_move_abs_m or 1.2
    local dir_count  = opts.dir_count or dft_path.nav_dir_count or 10
    local h_weight   = opts.heuristic_weight or dft_path.nav_heuristic_weight or 1.05

    local start_lvid, start_snap = opts.start_lvid, opts.start_pos
    if not start_lvid then
        start_lvid, start_snap = resolve_nav_vertex(start_pos, { max_scan_m = 30 })
    end
    if not start_lvid then return nil, false, 0, "bad_start_vertex" end

    local goal_lvid = opts.goal_lvid
    local goal_snap = opts.goal_pos
    if not goal_lvid then
        local goal_scan = opts.goal_scan_m or dft_path.nav_goal_scan_max_m or 60
        goal_lvid, goal_snap = resolve_nav_vertex(dest_pos, { max_scan_m = goal_scan, widen = true })
    end
    if not goal_lvid then return nil, false, 0, "bad_goal_vertex" end

    local goal_pos
    if goal_snap and goal_snap.x then
        goal_pos = vector():set(goal_snap.x, goal_snap.y, goal_snap.z)
    else
        local ok_gp, g_pos = pcall(function() return level.vertex_position(goal_lvid) end)
        if not (ok_gp and g_pos) then return nil, false, 0, "bad_vertex_pos" end
        goal_pos = vector():set(g_pos.x, g_pos.y, g_pos.z)
    end
    local ok_sp, s_pos = pcall(function() return level.vertex_position(start_lvid) end)
    if not (ok_sp and s_pos) then return nil, false, 0, "bad_vertex_pos" end
    local goal_drift = horizontal_dist(dest_pos, goal_pos) or dest_pos:distance_to(goal_pos)
    if goal_drift > (opts.goal_tol_m or dft_path.nav_goal_tol_m or 12) then
        dft_path_road_log("A* nav: goal vertex %.0fm from dest", goal_drift)
    end

    ensure_level_graph_cache()

    local fan_offsets
    if dir_count >= 10 then
        fan_offsets = { 0, 36, -36, 72, -72, 108, -108, 144, -144, 180 }
    elseif dir_count >= 8 then
        fan_offsets = { 0, 45, -45, 90, -90, 135, -135, 180 }
    else
        fan_offsets = { 0, 90, -90, 180 }
    end

    local function heuristic(pos)
        return (horizontal_dist(pos, goal_pos) or pos:distance_to(goal_pos)) * h_weight
    end

    local nodes = {}
    local start_h = heuristic(vector():set(s_pos.x, s_pos.y, s_pos.z))
    nodes[start_lvid] = {
        pos = vector():set(s_pos.x, s_pos.y, s_pos.z),
        g = 0, h = start_h, f = start_h, parent = nil, closed = false,
    }

    local heap = { items = {}, index = {} }
    heap_push(heap, nodes, start_lvid)

    local function is_near_road(pos)
        return graph_near_road_fast(pos, dft_path.road_on_graph_max_m or 5)
    end

    local road_seek_m = opts.road_seek_m or dft_path.nav_road_seek_m or 45

    local expanded = 0
    local best_lvid, best_h = start_lvid, start_h
    local goal_reached_lvid = nil

    while #heap.items > 0 and expanded < max_nodes do
        local cur_lvid = heap_pop(heap, nodes)
        local cur = nodes[cur_lvid]
        if cur and not cur.closed then
            cur.closed = true
            expanded = expanded + 1

            if cur.h < best_h then best_h = cur.h; best_lvid = cur_lvid end
            if cur.h <= goal_tol then goal_reached_lvid = cur_lvid; break end

            local remain_before = horizontal_dist(cur.pos, goal_pos) or cur.pos:distance_to(goal_pos)

            -- Roads only get their strong cost discount when the hop is actually closer to
            -- the destination afterward - a road that leads away/sideways is treated as a
            -- normal-cost move so the search won't wander down it just because it's free.
            local function consider(next_lvid, next_pos, moved)
                local remain_after = horizontal_dist(next_pos, goal_pos) or next_pos:distance_to(goal_pos)
                local progressing = remain_after < (remain_before - 0.05)
                local cost = moved
                if progressing and is_near_road(next_pos) then
                    cost = cost * road_mult
                end
                local tentative_g = cur.g + cost
                local existing = nodes[next_lvid]
                if not existing or (not existing.closed and tentative_g < existing.g) then
                    local h = heuristic(next_pos)
                    nodes[next_lvid] = {
                        pos = next_pos, g = tentative_g, h = h,
                        f = tentative_g + h, parent = cur_lvid, closed = false,
                    }
                    heap_decrease(heap, nodes, next_lvid)
                end
            end

            local bx, bz = goal_pos.x - cur.pos.x, goal_pos.z - cur.pos.z
            local blen = math.sqrt(bx * bx + bz * bz)
            local base_ang = (blen > 0.01) and atan2(bz, bx) or 0
            local step_this = math.min(step_m, math.max(blen, 1.0))

            for oi = 1, #fan_offsets do
                local ang = base_ang + math.rad(fan_offsets[oi])
                local dx, dz = math.cos(ang), math.sin(ang)
                local use_step = (fan_offsets[oi] == 0) and step_this or step_m
                local next_lvid, next_pos, moved = mesh_step_adaptive(cur_lvid, cur.pos, dx, dz, use_step, min_move_fr, min_move_abs)
                if next_lvid then
                    consider(next_lvid, next_pos, moved)
                end
            end

            -- Extra candidate: hop directly toward the nearest cached road-graph node (not just
            -- a generic compass direction) so the search can precisely latch onto and follow
            -- the road, as long as consider() above still finds it progresses toward the goal.
            local road_node = nearest_road_node_fast(cur.pos, road_seek_m)
            if road_node then
                local rdx = road_node.pos.x - cur.pos.x
                local rdz = road_node.pos.z - cur.pos.z
                local rdist = math.sqrt(rdx * rdx + rdz * rdz)
                if rdist > 1.5 then
                    local next_lvid, next_pos, moved = mesh_step_adaptive(cur_lvid, cur.pos, rdx, rdz, rdist, min_move_fr, min_move_abs)
                    if next_lvid then
                        consider(next_lvid, next_pos, moved)
                    end
                end
            end
        end
    end

    local reached = goal_reached_lvid ~= nil
    local end_lvid = goal_reached_lvid or best_lvid

    local rev, walk, guard = {}, end_lvid, 0
    while walk and guard < max_nodes + 10 do
        rev[#rev + 1] = walk
        walk = nodes[walk] and nodes[walk].parent
        guard = guard + 1
    end

    local chain = {}
    for i = #rev, 1, -1 do
        local n = nodes[rev[i]]
        chain[#chain + 1] = vector():set(n.pos.x, n.pos.y, n.pos.z)
    end
    -- Keep the actor's exact starting position (not the snapped start vertex) as point 1.
    chain[1] = vector():set(start_pos.x, start_pos.y, start_pos.z)

    dft_path_road_log(
        "A* nav: expanded=%d reached=%s best_h=%.0fm chain_pts=%d",
        expanded, tostring(reached), best_h, #chain
    )

    return chain, reached, expanded, reached and "ok" or "incomplete"
end

-- Greedy forward shortcutting: from point i, push the far endpoint j forward as long as a
-- direct mesh-validated line from i to j exists, then jump to j and repeat. Straightens the
-- A* zigzag (from compass-limited stepping) into a much cleaner polyline while keeping every
-- remaining vertex mesh-verified. O(n) shortcut checks in the common case.
smooth_navmesh_chain = function(chain, opts)
    if not chain or #chain < 3 then return chain end
    opts = opts or {}
    local no_land = opts.no_land_segments
    if not no_land or #no_land == 0 then
        local n = #chain
        local out = { chain[1] }
        local i = 1
        while i < n do
            local last_good = i + 1
            local j = i + 1
            while j < n do
                local nj = j + 1
                if mesh_line_reachable(chain[i], chain[nj], opts) then
                    last_good = nj
                    j = nj
                else
                    break
                end
            end
            out[#out + 1] = chain[last_good]
            i = last_good
        end
        return out
    end

    local ranges = {}
    local cursor = 1
    for s = 1, #no_land do
        local seg = no_land[s]
        local from_i = seg.from_idx or 1
        local to_i = seg.to_idx or from_i
        if from_i >= cursor then
            if from_i > cursor then
                ranges[#ranges + 1] = { cursor, from_i, false }
            end
            ranges[#ranges + 1] = { from_i, to_i, true }
            cursor = to_i + 1
        end
    end
    if cursor <= #chain then
        ranges[#ranges + 1] = { cursor, #chain, false }
    end
    if #ranges == 0 then
        ranges[1] = { 1, #chain, false }
    end

    local out = {}
    for r = 1, #ranges do
        local a, b, is_patch = ranges[r][1], ranges[r][2], ranges[r][3]
        if a <= b then
            local slice = {}
            for i = a, b do slice[#slice + 1] = chain[i] end
            local smoothed = is_patch and slice or smooth_navmesh_chain(slice, { no_land_segments = {} })
            local start_at = (#out == 0) and 1 or 2
            for i = start_at, #smoothed do
                out[#out + 1] = smoothed[i]
            end
        end
    end
    return (#out >= 2) and out or chain
end

-- Full pipeline: A* search + shortcut smoothing. Returns nil on failure (no navmesh API,
-- disconnected islands, search cap hit with too large a gap, etc.) so the caller can degrade
-- to a plain straight line instead of a partially-built/unsafe path.
-- Also returns the raw (pre-smoothing) A* vertex chain as a 5th value, unmodified, for the
-- debug preview - the smoothed chain is what's actually walked/teleported along.
build_navmesh_path = function(start_pos, dest_pos, build_opts)
    build_opts = build_opts or {}
    if not (start_pos and dest_pos) then return nil, nil, nil, false, "no_endpoints", nil end

    local start_anchor = build_opts.start_anchor or resolve_nav_anchor(start_pos, "start")
    local dest_anchor = build_opts.dest_anchor or resolve_nav_anchor(dest_pos, "dest")
    if not start_anchor or not dest_anchor then
        return nil, nil, nil, false, "no_nav_anchor", nil
    end

    local reach_cache = {}
    local astar_from = {
        start_lvid = start_anchor.lvid,
        goal_lvid = dest_anchor.lvid,
        goal_pos = dest_anchor.pos,
    }
    local astar_to = {
        start_lvid = dest_anchor.lvid,
        goal_lvid = start_anchor.lvid,
        goal_pos = start_anchor.pos,
    }

    local fwd_chain, fwd_reached, fwd_exp, fwd_reason = astar_navmesh_path(start_pos, dest_pos, astar_from)
    local raw_chain = fwd_chain
    local reached = fwd_reached
    local expanded = fwd_exp or 0
    local build_mode = "forward"
    local no_land_segments = {}

    if fwd_reached and fwd_chain and #fwd_chain >= 2 then
        build_mode = "forward"
    else
        local rev_chain, rev_reached, rev_exp = astar_navmesh_path(dest_pos, start_pos, astar_to)
        expanded = expanded + (rev_exp or 0)
        if rev_reached and rev_chain and #rev_chain >= 2 then
            raw_chain = reverse_nav_chain(rev_chain)
            reached = true
            build_mode = "reverse"
            dft_path_road_log("A* nav: bidirectional reverse reached (%d+%d nodes)", fwd_exp or 0, rev_exp or 0)
        elseif fwd_chain and #fwd_chain >= 1 and rev_chain and #rev_chain >= 1 then
            local linked, link_mode, no_land, link_gap = find_best_linked_path(
                fwd_chain, rev_chain, dest_pos, reach_cache
            )
            if linked and #linked >= 2 then
                raw_chain = linked
                reached = false
                build_mode = link_mode or "link"
                if no_land then no_land_segments[#no_land_segments + 1] = no_land end
                dft_path_road_log(
                    "A* nav: unified link %s gap=%.0fm (%d+%d nodes)",
                    build_mode, link_gap or 0, fwd_exp or 0, rev_exp or 0
                )
            else
                raw_chain = fwd_chain
                reached = false
                build_mode = "forward_partial"
            end
        else
            raw_chain = fwd_chain
            reached = false
            build_mode = fwd_chain and "forward_partial" or "no_chain"
        end
    end

    if not raw_chain or #raw_chain < 2 then
        return nil, nil, nil, false, fwd_reason or "no_chain", nil
    end

    raw_chain[1] = chain_copy_point(start_pos)

    local weak = apply_endpoint_connectors(
        raw_chain, start_pos, dest_pos, start_anchor, dest_anchor, reach_cache
    )

    if weak.dest and not build_opts.retried_dest and dest_anchor.scan_m then
        local last = raw_chain[#raw_chain]
        local better_dest = resolve_nav_anchor_reachable(dest_pos, last, dest_anchor.scan_m + 1)
        if better_dest then
            dft_path_road_log("A* nav: retrying with wider reachable dest anchor")
            return build_navmesh_path(start_pos, dest_pos, {
                retried_dest = true,
                start_anchor = start_anchor,
                dest_anchor = better_dest,
            })
        end
    end

    if weak.dest then
        -- Last mesh point cannot reach the exact click/dest position. Keep the navmesh
        -- portion and bridge the remainder with a NO_LAND patch (never discard the whole
        -- partial chain and fall back to a straight line).
        local last = raw_chain[#raw_chain]
        local gap = last and chain_point_dist(last, dest_pos) or nil
        if last and gap and gap > 0.5 then
            local patch_from = #raw_chain
            raw_chain[#raw_chain + 1] = chain_copy_point(dest_pos)
            no_land_segments[#no_land_segments + 1] = { from_idx = patch_from, to_idx = #raw_chain }
            if not reached then
                build_mode = (build_mode or "partial") .. "_dest_patch"
            else
                build_mode = (build_mode or "forward") .. "_dest_patch"
            end
            dft_path_road_log(
                "A* nav: dest patch NO_LAND (%.0fm, %d pts, reached=%s)",
                gap, #raw_chain, tostring(reached)
            )
        elseif not reached then
            dft_path_road_log("A* nav: weak dest connector (drift beyond mesh hop)")
            return nil, nil, nil, false, "final_hop_blocked", nil
        end
    end

    local path_meta = build_path_meta(raw_chain, no_land_segments, build_mode)
    local smoothed = smooth_navmesh_chain(raw_chain, { no_land_segments = no_land_segments })
    local is_vertex = {}
    for i = 1, #smoothed do
        local unsafe = false
        for s = 1, #no_land_segments do
            if is_no_land_segment(no_land_segments[s], i) then
                unsafe = true
                break
            end
        end
        is_vertex[i] = (i > 1) and not unsafe
    end
    local path_len = polyline_length(smoothed)
    dft_path_road_log(
        "A* nav: smoothed %d -> %d points, path=%.0fm (mode=%s nodes expanded=%d patches=%d)",
        #raw_chain, #smoothed, path_len, build_mode, expanded, #no_land_segments
    )
    return smoothed, is_vertex, path_len, true, raw_chain, path_meta
end

-- Sample a position at cumulative-distance ratio (0..1) along an arbitrary polyline.
-- Used to keep ambush checks, emission/encounter interrupts, and arrival landings all
-- reading from the exact same path that was built and displayed for the journey.
polyline_pos_at_ratio = function(chain, ratio)
    if not chain or #chain < 2 then return nil, 0 end
    ratio = math.max(0, math.min(ratio or 0, 1.0))
    local seg_count = #chain - 1
    local seg_lens = {}
    local total = 0
    for i = 1, seg_count do
        local d = dft_distance_pda(chain[i], chain[i + 1]) or chain[i]:distance_to(chain[i + 1])
        seg_lens[i] = d
        total = total + d
    end
    if total <= 0.001 then
        local p = chain[1]
        return vector():set(p.x, p.y, p.z), 0
    end
    local target = total * ratio
    local along = 0
    for i = 1, seg_count do
        local seg_len = seg_lens[i]
        if (along + seg_len) >= target or i == seg_count then
            local remain = target - along
            local t = (seg_len > 0.001) and math.min(remain / seg_len, 1.0) or 0
            local out = vector()
            lerp_pos(chain[i], chain[i + 1], t, out)
            return out, total
        end
        along = along + seg_len
    end
    local last = chain[#chain]
    return vector():set(last.x, last.y, last.z), total
end

-- Snap a journey ratio to the nearest safe nav vertex on the path (never inside NO_LAND patches).
local function polyline_safe_pos_at_ratio(chain, ratio, meta)
    if not chain or #chain < 2 then return nil, 0 end
    ratio = math.max(0, math.min(ratio or 0, 1.0))
    local safe = meta and meta.safe_vertices
    if not safe or #safe == 0 then
        return polyline_pos_at_ratio(chain, ratio)
    end

    local seg_count = #chain - 1
    local seg_lens = {}
    local total = 0
    for i = 1, seg_count do
        local d = dft_distance_pda(chain[i], chain[i + 1]) or chain[i]:distance_to(chain[i + 1])
        seg_lens[i] = d
        total = total + d
    end
    if total <= 0.001 then
        return chain_copy_point(chain[1]), 0
    end

    local cum_at = {}
    cum_at[1] = 0
    for i = 1, seg_count do
        cum_at[i + 1] = cum_at[i] + seg_lens[i]
    end

    local target_dist = total * ratio
    local best_idx, best_delta = safe[1], math.huge
    for si = 1, #safe do
        local idx = safe[si]
        local cum = cum_at[idx] or 0
        local delta = math.abs(cum - target_dist)
        if delta < best_delta then
            best_delta = delta
            best_idx = idx
        end
    end
    return chain_copy_point(chain[best_idx]), total
end

local function path_cache_key(start_pos, dest_pos)
    if not (start_pos and dest_pos) then return nil end
    return string.format(
        "%.0f_%.0f_%.0f|%.0f_%.0f_%.0f",
        start_pos.x, start_pos.y, start_pos.z,
        dest_pos.x, dest_pos.y, dest_pos.z
    )
end

get_cached_line_snap_path = function(start_pos, dest_pos)
    local cache = dft.path_build_cache
    if not cache then return nil end
    local key = path_cache_key(start_pos, dest_pos)
    if not key or cache.key ~= key then return nil end
    -- Live routing is coarse-only; reject stale fine-mesh / straight caches from older builds.
    if not (cache.meta and cache.meta.mode == "coarse_graph") then
        return nil
    end
    return cache.chain, cache.is_vertex, cache.path_len, cache.raw_chain, cache.meta
end

local function store_line_snap_path_cache(start_pos, dest_pos, chain, is_vertex, path_len, raw_chain, meta)
    local key = path_cache_key(start_pos, dest_pos)
    if not key then return end
    dft.path_build_cache = {
        key = key,
        chain = chain,
        is_vertex = is_vertex,
        path_len = path_len,
        raw_chain = raw_chain,
        meta = meta,
    }
end

-- Primary (and only) path builder for preview, journey dots, and mid-journey teleports.
-- Coarse nav graph only — no fine navmesh A*, no straight-line fallback.
-- Optional 3rd arg: dest_anchor_key ("base:id" / "transition:id" / "campfire:id").
build_line_snap_path = function(start_pos, dest_pos, dest_anchor_key)
    if not (start_pos and dest_pos) then return {}, {}, 0, {}, nil end

    local cached_chain, cached_is_vertex, cached_len, cached_raw, cached_meta = get_cached_line_snap_path(start_pos, dest_pos)
    if cached_chain and #cached_chain >= 2 then
        return cached_chain, cached_is_vertex, cached_len, cached_raw, cached_meta
    end

    local chain, is_vertex, path_len, meta
    if _G.dft_coarse_nav_build_path then
        local ok, c, iv, plen, m = pcall(_G.dft_coarse_nav_build_path, start_pos, dest_pos, dest_anchor_key)
        if ok and c and #c >= 2 then
            chain, is_vertex, path_len, meta = c, iv, plen, m
        elseif not ok then
            dft_log_error("path build: coarse nav error: %s", tostring(c))
        end
    end

    if not (chain and #chain >= 2) then
        dft_log_error("path build: coarse nav failed at start=%s dest=%s key=%s",
            dft_vec_str(start_pos), dft_vec_str(dest_pos), tostring(dest_anchor_key))
        return {}, {}, 0, {}, nil
    end

    dft_path_road_log(
        "build (coarse graph): start=%s dest=%s points=%d path=%.0fm key=%s",
        dft_vec_str(start_pos), dft_vec_str(dest_pos), #chain, path_len or 0,
        tostring(dest_anchor_key or "?")
    )
    store_line_snap_path_cache(start_pos, dest_pos, chain, is_vertex, path_len, chain, meta)
    return chain, is_vertex, path_len, chain, meta
end

-- Fixed-spacing samples along an existing polyline. Skips interiors of NO_LAND patch segments.
densify_polyline = function(chain, spacing_m, max_count, meta)
    spacing_m = spacing_m or dft_path.dot_spacing_m or 20
    max_count = max_count or dft_path.dot_max_count
    if not chain or #chain < 2 then return {} end

    local function seg_is_no_land(seg_i)
        local patches = meta and meta.no_land_segments
        if not patches then return false end
        for s = 1, #patches do
            local seg = patches[s]
            if seg_i >= (seg.from_idx or 1) and seg_i < (seg.to_idx or 0) then
                return true
            end
        end
        return false
    end

    local seg_count = #chain - 1
    local seg_lens = {}
    local total = 0
    for i = 1, seg_count do
        local d = dft_distance_pda(chain[i], chain[i + 1]) or chain[i]:distance_to(chain[i + 1])
        seg_lens[i] = d
        if not seg_is_no_land(i) then
            total = total + d
        end
    end
    if total < spacing_m * 0.5 then return {} end

    local out = {}
    local interp = vector()
    local along = spacing_m
    local walked = 0
    for seg_i = 1, seg_count do
        local seg_len = seg_lens[seg_i]
        if seg_is_no_land(seg_i) then
            walked = walked + seg_len
        else
            while along <= walked + seg_len and along < total and #out < max_count do
                local seg_off = along - walked
                local t = (seg_len > 0) and (seg_off / seg_len) or 0
                lerp_pos(chain[seg_i], chain[seg_i + 1], t, interp)
                out[#out + 1] = vector():set(interp.x, interp.y + 0.1, interp.z)
                along = along + spacing_m
            end
            walked = walked + seg_len
        end
    end
    return out
end

-- Preview debug markers: grey = dense samples along the final smoothed path actually walked;
-- green = every raw A* vertex, unmodified, before the shortcut-smoothing pass. Comparing the
-- two shows exactly how much smoothing straightened out the search's zig-zagging mesh walk.
build_preview_markers = function(chain, raw_chain)
    local markers = {}
    if not chain or #chain < 2 then return markers end

    local edge_sp = dft_path.preview_edge_spacing_m or 5
    for seg = 1, #chain - 1 do
        local a, b = chain[seg], chain[seg + 1]
        local seg_len = dft_distance_pda(a, b) or a:distance_to(b)
        if seg_len > 0.5 then
            local along = edge_sp
            while along < seg_len and #markers < dft_path.dot_max_count do
                local interp = vector()
                lerp_pos(a, b, along / seg_len, interp)
                markers[#markers + 1] = {
                    pos = vector():set(interp.x, interp.y + 0.1, interp.z),
                    spot = dft_path.dot_spot_debug_edge,
                }
                along = along + edge_sp
            end
        end
    end

    if raw_chain and #raw_chain > 2 then
        for i = 2, #raw_chain - 1 do
            if #markers < dft_path.dot_max_count then
                local p = raw_chain[i]
                markers[#markers + 1] = {
                    pos = vector():set(p.x, p.y + 0.1, p.z),
                    spot = dft_path.dot_spot_debug_vertex,
                }
            end
        end
    end
    return markers
end

-- Authoritative ratio->position lookup for the active journey. Prefers the exact polyline
-- that was built (and displayed) for this trip so ambush checks, emission/encounter
-- interrupts, and arrival landings all agree on where "ratio% of the way there" actually
-- is; falls back to a raw straight-line lerp only if no journey chain is available.
--
-- Coarse nodes sit on fine navmesh, but mid-segment ratio points are chords between those
-- nodes. Prefer snapping to the nearer of (nearest coarse path node, nearest fine nav
-- vertex) when either is within land_prefer_node_m; otherwise fall back to ground-ray.
local function get_safe_lvid_pos(ratio)
    local intended = nil
    if dft.path_chain and #dft.path_chain >= 2 then
        intended = polyline_safe_pos_at_ratio(dft.path_chain, ratio, dft.path_chain_meta)
    end
    if not intended then
        if not (dft.start_pos and dft.dest_pos) then return nil end
        intended = vector()
        lerp_pos(dft.start_pos, dft.dest_pos, ratio, intended)
    end

    local prefer_m = (dft_path and dft_path.land_prefer_node_m) or 12
    local best_pos, best_lvid, best_d = nil, nil, prefer_m

    local function consider(pos, lvid)
        if not (pos and pos.x) then return end
        local d = horizontal_dist(intended, pos) or intended:distance_to(pos)
        if d and d < best_d then
            best_d = d
            best_pos = vector():set(pos.x, pos.y, pos.z)
            best_lvid = lvid
        end
    end

    -- Nearest coarse node on this journey's polyline.
    local chain = dft.path_chain
    local is_vertex = dft.path_chain_is_vertex
    if chain then
        for i = 1, #chain do
            if (not is_vertex) or is_vertex[i] or i == 1 or i == #chain then
                local p = chain[i]
                local lvid = nil
                if level and level.vertex_id then
                    local ok, v = pcall(function() return level.vertex_id(p) end)
                    if ok and valid_lvid(v) and lvid_accessible(v) then lvid = v end
                end
                consider(p, lvid)
            end
        end
    end

    -- Nearest fine navmesh vertex within the same prefer radius.
    if level and level.vertex_id and level.vertex_position then
        local ok, lvid = pcall(function() return level.vertex_id(intended) end)
        if ok and valid_lvid(lvid) and lvid_accessible(lvid) then
            local ok_p, vp = pcall(function() return level.vertex_position(lvid) end)
            if ok_p and vp then consider(vp, lvid) end
        end
        local near_lvid, near_pos = nearest_accessible_nav_vertex(intended, prefer_m)
        if near_lvid and near_pos then
            consider(near_pos, near_lvid)
        end
    end

    if best_pos then
        return best_pos, best_lvid
    end

    -- Nothing within prefer_m — ground/ray snap near the intended point.
    local scan_m = 28
    local snapped, snap_lvid = find_ground_pos(intended, nil, dft.dest_gvid, {
        anchor = intended,
        max_drift_m = scan_m,
        local_only = true,
        ray_first = true,
    })
    if snapped then
        local lvid = snap_lvid or resolve_lvid_for_pos(snapped, nil, dft.dest_gvid)
        return snapped, lvid
    end
    local lvid = resolve_lvid_for_pos(intended, nil, dft.dest_gvid)
    return intended, lvid
end

local function build_path_dots(start_pos, dest_pos, dest_anchor_key)
    local straight = dft_distance_pda(start_pos, dest_pos) or start_pos:distance_to(dest_pos)
    local chain, is_vertex, path_len, _raw, path_meta = build_line_snap_path(start_pos, dest_pos, dest_anchor_key)

    if #chain < 2 then
        dft_log("path: build failed (%.0fm straight)", straight)
        dft.path_chain = nil
        dft.path_chain_is_vertex = nil
        dft.path_chain_meta = nil
        return {}, straight
    end

    dft.path_chain = chain
    dft.path_chain_is_vertex = is_vertex
    dft.path_chain_meta = path_meta

    local vtx_count = 0
    for i = 2, #chain - 1 do
        if is_vertex[i] then vtx_count = vtx_count + 1 end
    end

    local positions = densify_polyline(chain, dft_path.dot_spacing_m, nil, path_meta)
    dft_log("path: %d pts (%d verts) -> %d dots @ %dm, %.0fm (straight %.0fm) mode=%s",
        #chain, vtx_count, #positions, dft_path.dot_spacing_m, path_len, straight,
        tostring(path_meta and path_meta.mode or "?"))

    return positions, path_len
end

path_stats_for_target = function(id, ln, click_pos)
    if not (db.actor and id and id > 0 and id ~= 65535) then return nil end
    local target, terr = dft_resolve_travel_target(id, ln, click_pos)
    if not target or not target.pos then return { error = terr or "no_target" } end
    local start = db.actor:position()
    local straight = dft_distance_pda(start, target.pos) or start:distance_to(target.pos)
    local dest_key = _G.dft_coarse_nav_dest_anchor_key and _G.dft_coarse_nav_dest_anchor_key(id) or nil
    local chain, is_vertex, path_len, _raw, path_meta
    local menu_cache = dft.menu_path_cache
    if menu_cache and menu_cache.seq == dft.menu_open_seq and menu_cache.id == id
        and menu_cache.meta and menu_cache.meta.mode == "coarse_graph"
        and menu_cache.chain and #menu_cache.chain >= 2 then
        chain = menu_cache.chain
        is_vertex = menu_cache.is_vertex
        path_len = menu_cache.path_len
        path_meta = menu_cache.meta
    else
        chain, is_vertex, path_len, _raw, path_meta = get_cached_line_snap_path(start, target.pos)
        if not chain then
            chain, is_vertex, path_len, _raw, path_meta = build_line_snap_path(start, target.pos, dest_key)
        end
    end
    local vtx_count = 0
    for i = 2, #(chain or {}) - 1 do
        if is_vertex and is_vertex[i] then vtx_count = vtx_count + 1 end
    end
    local dots = (chain and #chain >= 2) and densify_polyline(chain, dft_path.dot_spacing_m, nil, path_meta) or {}
    return {
        dest = target.pos,
        straight = straight,
        path_len = path_len or straight,
        vertex_count = #dots,
        vertex_snaps = vtx_count,
        failed = not chain or #chain < 2,
    }
end

local function report_map_click(map_table, hint)
    if not map_table then return end
    local id = map_table.object_id
    local ln = map_table.level_name
    local click_pos = map_table.pos
    dft.last_map_click_pos = click_pos

    pcall(function()
        for k, v in pairs(map_table) do
            dft_log(" map_table.%s = %s", tostring(k), tostring(v))
        end
    end)

    local se_obj = (id and id > 0 and id ~= 65535) and alife_object(id) or nil
    local obj_pos = se_obj and dft_object_position(se_obj, id) or nil
    local click_off = (click_pos and obj_pos) and dft_distance_pda(click_pos, obj_pos) or nil
    local spots = (id and id > 0 and id ~= 65535) and dft_collect_object_spots(id) or {}
    local lc_spot = id and dft_get_level_changer_spot(id) or nil
    local clicked_spot = hint
    if (not clicked_spot or clicked_spot == "") and lc_spot then
        clicked_spot = lc_spot
    end

    local kind = "empty_map"
    if id and id > 0 and id ~= 65535 then
        local parts = {}
        if clicked_spot and clicked_spot ~= "" then
            parts[#parts + 1] = "icon=" .. tostring(clicked_spot)
        end
        if lc_spot then parts[#parts + 1] = "lc=" .. lc_spot end
        if #spots > 0 then parts[#parts + 1] = "spots=[" .. table.concat(spots, ",") .. "]" end
        if dft_is_campfire(id, se_obj) then parts[#parts + 1] = "campfire" end
        if dft_is_base(id, se_obj) then parts[#parts + 1] = "base" end
        if dft_is_player_stash(id, se_obj) then parts[#parts + 1] = "stash" end
        if dft_is_pda_transition(id) then parts[#parts + 1] = "transition" end
        kind = (#parts > 0) and table.concat(parts, " ") or "object"
    end

    local tinfo = se_obj and dft_read_transition_dest_info(se_obj) or nil
    local trans_line = ""
    if tinfo then
        if tinfo.dest_level then trans_line = trans_line .. " -> " .. tinfo.dest_level end
        if tinfo.dest_gvid then trans_line = trans_line .. " gvid=" .. tostring(tinfo.dest_gvid) end
        if tinfo.dest_pos then trans_line = trans_line .. " trans_pos=" .. dft_vec_str(tinfo.dest_pos) end
    end

    local path_line = ""
    if se_obj and dft_is_travel_destination(id) then
        local skip_path_build = path_preview_enabled()
        local stats
        if skip_path_build then
            local target = dft_resolve_travel_target(id, ln, click_pos)
            if target and target.pos then
                local straight = db.actor and (
                    dft_distance_pda(db.actor:position(), target.pos)
                    or db.actor:position():distance_to(target.pos)
                ) or 0
                stats = {
                    dest = target.pos,
                    straight = straight,
                    path_len = straight,
                    vertex_count = 0,
                    vertex_snaps = 0,
                    failed = false,
                }
            end
        else
            stats = path_stats_for_target(id, ln, click_pos)
        end
        if stats and stats.error then
            path_line = " | path=unresolved reason=" .. tostring(stats.error)
        elseif stats then
            path_line = string.format(
                " | travel=%s straight=%.0fm path=%.0fm dots=%d vtx=%d%s",
                dft_vec_str(stats.dest), stats.straight, stats.path_len,
                stats.vertex_count, stats.vertex_snaps,
                stats.failed and " FAILED" or ""
            )
            if tinfo and tinfo.dest_pos and obj_pos then
                local td = dft_distance_pda(obj_pos, tinfo.dest_pos)
                if td and td > 1 then
                    path_line = path_line .. string.format(" lc_obj_vs_trans=%.0fm", td)
                end
            end
        end
    end

    dft_log(
        "map-rclick: id=%s ln=%s hint=%s click=%s obj=%s off=%.0fm | %s%s%s",
        tostring(id), tostring(ln), tostring(hint or "none"),
        dft_vec_str(click_pos), dft_vec_str(obj_pos), click_off or -1,
        kind, trans_line, path_line
    )

    if not dft.is_traveling and id and id > 0 and id ~= 65535 and dft_is_travel_destination(id) then
        if path_preview_enabled() and dft_preview_eligible then
            dft.last_menu_target_id = id
            dft.last_menu_target_ln = ln
            local can_preview, preview_lc = dft_preview_eligible(id, se_obj, ln)
            if can_preview then
                pcall(function() build_path_preview(id, preview_lc) end)
            end
        end
    end
end

local function assign_dot_path_ratios(positions, path_len, origin_pos)
    dft.dot_path_ratio = {}
    if not positions or #positions == 0 then return end
    if not path_len or path_len <= 0 then
        for i = 1, #positions do
            dft.dot_path_ratio[i] = i / (#positions + 1)
        end
        return
    end
    local cum = 0
    local prev = origin_pos or dft.start_pos or (db.actor and db.actor:position())
    for i = 1, #positions do
        if prev then
            cum = cum + (dft_distance_pda(prev, positions[i]) or prev:distance_to(positions[i]))
        end
        dft.dot_path_ratio[i] = math.min(cum / path_len, 1.0)
        prev = positions[i]
    end
end

local function remove_path_spots(obj_id)
    if not obj_id then return end
    pcall(function()
        for i = 1, #dft_path.dots do
            local spot = dft_path.dots[i]
            if level.map_has_object_spot(obj_id, spot) ~= 0 then
                level.map_remove_object_spot(obj_id, spot)
            end
        end
    end)
end

local function purge_stuck_dot_pdas(include_path_spots)
    local sim = alife()
    if not sim then return 0 end
    local purged = 0
    local function try_purge(obj)
        if not obj then return end
        local cls = 0
        pcall(function() cls = obj:clsid() end)
        if cls ~= clsid.device_pda or obj:section_name() ~= "device_pda" then return end
        local has_spot = false
        pcall(function()
            has_spot = (level.map_has_object_spot(obj.id, "primary_object") ~= 0)
                    or (level.map_has_object_spot(obj.id, "green_location") ~= 0)
            if include_path_spots then
                local all_spots = dft_path.dots
                for i = 1, #all_spots do
                    if level.map_has_object_spot(obj.id, all_spots[i]) ~= 0 then
                        has_spot = true
                        break
                    end
                end
            end
        end)
        if not has_spot then return end
        if include_path_spots then remove_path_spots(obj.id) end
        pcall(function() level.map_remove_object_spot(obj.id, "primary_object") end)
        pcall(function() level.map_remove_object_spot(obj.id, "green_location") end)
        pcall(alife_release, obj)
        purged = purged + 1
    end
    if sim.iterate_objects then
        sim:iterate_objects(try_purge)
    else
        for i = 1, 65534 do try_purge(sim:object(i)) end
    end
    return purged
end

-- The dot's alife object only exists to carry a map spot (level.map_add_object_spot_ser draws
-- from the object's own live position, x/z only - the 3D game world never factors in). Bury it
-- deep underground so it can never be seen or walked into, and strip its physics the moment it
-- comes online so the engine doesn't try to resolve the underground interpenetration by popping
-- it back up to the surface.
local function freeze_buried_dot(obj_id, attempts_left)
    attempts_left = attempts_left or 8
    local obj = level.object_by_id(obj_id)
    if obj then
        pcall(function()
            local shell = obj:get_physics_shell()
            if shell then
                shell:set_active(false)
                shell:set_ignore_gravity(true)
            end
        end)
        return
    end
    if attempts_left <= 0 then return end
    CreateTimeEvent("dft", "freeze_dot_" .. tostring(obj_id), 0.2, function()
        freeze_buried_dot(obj_id, attempts_left - 1)
        return true
    end)
end

local function ensure_path_dot(index, as_pending, spot_override)
    if dft.dot_ids[index] then return end
    local dp = dft.dot_positions[index]
    if not (dp and db.actor) then return end
    local lvid = level.vertex_id(dp)
    if not lvid or lvid == 4294967295 or lvid == -1 then
        lvid = db.actor:level_vertex_id()
    end
    local buried = vector():set(dp.x, dp.y - (dft_path.dot_underground_offset_m or 100), dp.z)
    local se = alife_create("device_pda", buried, lvid, db.actor:game_vertex_id())
    if not se then return end
    -- Track it immediately, before anything else that could error, so a spot-add failure can
    -- never leave an untracked (and therefore never-released) alife object behind.
    dft.dot_ids[index] = se.id
    local spot = spot_override
        or (as_pending and dft_path.dot_spot_pending or dft_path.dot_spot)
    pcall(level.map_add_object_spot_ser, se.id, spot, "")
    freeze_buried_dot(se.id)
    if not dft.dot_path_ratio[index] then
        local count = dft.dot_count or #dft.dot_positions
        dft.dot_path_ratio[index] = index / (count + 1)
    end
end

local function promote_path_dot(index)
    local obj_id = dft.dot_ids[index]
    if not obj_id or dft.dot_done[index] then return end
    dft.dot_done[index] = true
    pcall(function()
        if level.map_has_object_spot(obj_id, dft_path.dot_spot_pending) ~= 0 then
            level.map_remove_object_spot(obj_id, dft_path.dot_spot_pending)
        end
        if level.map_has_object_spot(obj_id, dft_path.dot_spot) == 0 then
            level.map_add_object_spot_ser(obj_id, dft_path.dot_spot, "")
        end
    end)
end

-- Index of the dot whose path-ratio is closest to the given ratio - used to find "the dot
-- nearest where this just happened" for ambush/dodge feedback, regardless of whether that
-- dot has already been promoted to green yet.
nearest_dot_index_for_ratio = function(ratio)
    local d_count = dft.dot_count or 0
    if d_count == 0 then return nil end
    local best_i, best_diff
    for i = 1, d_count do
        local r = dft.dot_path_ratio[i] or (i / (d_count + 1))
        local diff = math.abs(r - ratio)
        if not best_diff or diff < best_diff then
            best_diff = diff
            best_i = i
        end
    end
    return best_i
end

-- Force the dot nearest to `ratio` to a specific outcome spot (red ambush / blue dodge)
-- instead of the normal grey->green promotion, so the PDA map keeps a visible record of
-- where along the route something actually happened.
local function mark_dot_outcome(ratio, spot_name)
    local idx = nearest_dot_index_for_ratio(ratio)
    if not idx then return end
    if not dft.dot_ids[idx] then
        ensure_path_dot(idx, true)
    end
    dft.dot_done[idx] = true
    local obj_id = dft.dot_ids[idx]
    if not obj_id then return end
    pcall(function()
        local all_spots = dft_path.dots
        for i = 1, #all_spots do
            if level.map_has_object_spot(obj_id, all_spots[i]) ~= 0 then
                level.map_remove_object_spot(obj_id, all_spots[i])
            end
        end
        level.map_add_object_spot_ser(obj_id, spot_name, "")
        if spot_name == dft_path.dot_spot_ambush and dft_path.dot_spot_ambush_icon then
            level.map_add_object_spot_ser(obj_id, dft_path.dot_spot_ambush_icon, "")
        end
    end)
end

-- Revert any already-promoted dots past an ambush point back to grey (pending).
local function freeze_dots_beyond_ratio(ratio)
    local ambush_idx = nearest_dot_index_for_ratio(ratio)
    if not ambush_idx then return end
    local d_count = dft.dot_count or 0
    for i = ambush_idx + 1, d_count do
        local obj_id = dft.dot_ids[i]
        if obj_id and dft.dot_done[i] then
            dft.dot_done[i] = false
            pcall(function()
                if level.map_has_object_spot(obj_id, dft_path.dot_spot) ~= 0 then
                    level.map_remove_object_spot(obj_id, dft_path.dot_spot)
                end
                if level.map_has_object_spot(obj_id, dft_path.dot_spot_pending) == 0 then
                    level.map_add_object_spot_ser(obj_id, dft_path.dot_spot_pending, "")
                end
            end)
        end
    end
end

local function clear_ambush_range_circle()
    local ids = dft.ambush_range_ids
    if not (ids and #ids > 0) then
        dft.ambush_range_ids = {}
        dft.ambush_range_last = nil
        return
    end
    local spot_n = dft_path.ambush_range_spot or "dft_ambush_range_ring"
    local spot_a = dft_path.ambush_range_spot_alert or "dft_ambush_range_ring_alert"
    for i = 1, #ids do
        local id = ids[i]
        pcall(function()
            if level.map_has_object_spot(id, spot_n) ~= 0 then
                level.map_remove_object_spot(id, spot_n)
            end
            if level.map_has_object_spot(id, spot_a) ~= 0 then
                level.map_remove_object_spot(id, spot_a)
            end
        end)
        local obj = alife_object(id)
        if obj then pcall(alife_release, obj) end
    end
    dft.ambush_range_ids = {}
    dft.ambush_range_last = nil
end

local function append_ambush_range_ring(center_pos, radius_m, spot, segments, out_ids)
    if not (center_pos and radius_m and radius_m > 0 and spot and segments and segments > 0) then
        return
    end
    local offset = dft_path.dot_underground_offset_m or 100
    local lvid = db.actor:level_vertex_id()
    local gvid = db.actor:game_vertex_id()
    for i = 0, segments - 1 do
        local angle = (2 * math.pi * i) / segments
        local pos = vector():set(
            center_pos.x + math.cos(angle) * radius_m,
            center_pos.y,
            center_pos.z + math.sin(angle) * radius_m
        )
        local buried = vector():set(pos.x, pos.y - offset, pos.z)
        local se = alife_create("device_pda", buried, lvid, gvid)
        if se then
            out_ids[#out_ids + 1] = se.id
            pcall(level.map_add_object_spot_ser, se.id, spot, "")
            freeze_buried_dot(se.id)
        end
    end
end

local function update_ambush_range_circle(center_pos, los_radius_m, alert_kind, close_radius_m)
    if not (center_pos and los_radius_m and los_radius_m > 0 and db.actor) then
        clear_ambush_range_circle()
        return
    end
    local spot_y = dft_path.ambush_range_spot or "dft_ambush_range_ring"
    local spot_r = dft_path.ambush_range_spot_alert or "dft_ambush_range_ring_alert"
    -- Only the band that triggered the ambush turns red; the other stays yellow.
    local close_spot = (alert_kind == "close") and spot_r or spot_y
    local los_spot = (alert_kind == "los") and spot_r or spot_y
    clear_ambush_range_circle()
    dft.ambush_range_ids = {}
    local close_r = close_radius_m or 0
    if close_r > 0 and close_r < los_radius_m then
        append_ambush_range_ring(center_pos, close_r, close_spot,
            dft_path.ambush_range_close_segments or 24, dft.ambush_range_ids)
    end
    append_ambush_range_ring(center_pos, los_radius_m, los_spot,
        dft_path.ambush_range_segments or 32, dft.ambush_range_ids)
    dft.ambush_range_last = {
        close_r = close_r,
        los_r = los_radius_m,
        radius = los_radius_m,
        cx = center_pos.x,
        cz = center_pos.z,
        alert_kind = alert_kind or false,
    }
end

local function sync_ambush_range_circle()
    local cfg = _G.dft_config
    if not (cfg and cfg.show_ambush_range) then
        if dft.ambush_range_ids and #dft.ambush_range_ids > 0 then
            clear_ambush_range_circle()
        end
        return
    end
    local pda_shown = false
    pcall(function()
        if ActorMenu and ActorMenu.get_pda_menu then
            local pda = ActorMenu.get_pda_menu()
            if pda and pda:IsShown() then pda_shown = true end
        end
    end)
    if not pda_shown then
        if dft.ambush_range_ids and #dft.ambush_range_ids > 0 then
            clear_ambush_range_circle()
        end
        return
    end
    if not (db.actor and db.actor:alive()) then return end

    local sneaky = dft.is_traveling and dft.travel_mode == "sneaky"
    local los_r = dft_ambush_radius_m(sneaky)
    local close_r = dft_ambush_close_radius_m(sneaky)
    -- Smooth journey point on the polyline (not land-snap / coarse-node snap — that lagged
    -- behind the walking dots). Teleport landings still use get_safe_lvid_pos separately.
    local center = db.actor:position()
    if dft.is_traveling and dft.travel_dist and dft.travel_dist > 0
        and dft.path_chain and #dft.path_chain >= 2 then
        local ratio = math.min((dft.current_dist or 0) / dft.travel_dist, 1.0)
        local vpos = polyline_pos_at_ratio(dft.path_chain, ratio)
        if vpos then center = vpos end
    end

    local alert_kind = false
    if dft.is_traveling and dft.ambush_pending then
        alert_kind = dft.ambush_kind or "los"
    end
    local last = dft.ambush_range_last
    if last and last.los_r == los_r and last.close_r == close_r and last.alert_kind == alert_kind
        and math.abs((last.cx or 0) - center.x) < 2
        and math.abs((last.cz or 0) - center.z) < 2 then
        return
    end
    update_ambush_range_circle(center, los_r, alert_kind, close_r)
end

local function clear_ambush_dir_marker()
    local ids = dft.ambush_dir_ids
    if not (ids and #ids > 0) then
        dft.ambush_dir_ids = {}
        return
    end
    local spot = dft_path.ambush_dir_spot or dft_path.dot_spot_ambush_icon or "dft_path_dot_ambush_icon"
    for i = 1, #ids do
        local id = ids[i]
        pcall(function()
            if level.map_has_object_spot(id, spot) ~= 0 then
                level.map_remove_object_spot(id, spot)
            end
            if level.map_has_object_spot(id, dft_path.dot_spot_ambush) ~= 0 then
                level.map_remove_object_spot(id, dft_path.dot_spot_ambush)
            end
        end)
        local obj = alife_object(id)
        if obj then pcall(alife_release, obj) end
    end
    dft.ambush_dir_ids = {}
end

-- Red waypoint-style pin(s) along the bearing to the nearest ambusher, ~10s then clear.
local function show_ambush_dir_marker(targets, from_pos)
    clear_ambush_dir_marker()
    if not (targets and db.actor) then return end
    local origin = from_pos or db.actor:position()
    local hostile = nearest_hostile_world(targets, origin)
    if not (hostile and origin) then return end
    local dx = hostile.x - origin.x
    local dz = hostile.z - origin.z
    local horiz = math.sqrt(dx * dx + dz * dz)
    if horiz < 1.0 then
        dx, dz, horiz = 1, 0, 1
    end
    local ux, uz = dx / horiz, dz / horiz
    local offset = dft_path.dot_underground_offset_m or 100
    local lvid = db.actor:level_vertex_id()
    local gvid = db.actor:game_vertex_id()
    local spot_pin = dft_path.ambush_dir_spot or dft_path.dot_spot_ambush_icon or "dft_path_dot_ambush_icon"
    local spot_dot = dft_path.dot_spot_ambush or "dft_path_dot_ambush"
    dft.ambush_dir_ids = {}

    -- Shaft: a few red dots between the landing and the threat (minimap direction cue).
    local shaft_n = math.min(4, math.max(1, math.floor(horiz / 18)))
    for i = 1, shaft_n do
        local t = (i / (shaft_n + 1)) * math.min(horiz, 80)
        local pos = vector():set(origin.x + ux * t, origin.y, origin.z + uz * t)
        local buried = vector():set(pos.x, pos.y - offset, pos.z)
        local se = alife_create("device_pda", buried, lvid, gvid)
        if se then
            dft.ambush_dir_ids[#dft.ambush_dir_ids + 1] = se.id
            pcall(level.map_add_object_spot_ser, se.id, spot_dot, "")
            freeze_buried_dot(se.id)
        end
    end

    -- Tip: waypoint pin on the nearest hostile.
    local tip = vector():set(hostile.x, origin.y, hostile.z)
    local buried_tip = vector():set(tip.x, tip.y - offset, tip.z)
    local tip_se = alife_create("device_pda", buried_tip, lvid, gvid)
    if tip_se then
        dft.ambush_dir_ids[#dft.ambush_dir_ids + 1] = tip_se.id
        pcall(level.map_add_object_spot_ser, tip_se.id, spot_pin, "")
        freeze_buried_dot(tip_se.id)
    end

    local ttl = (_G.dft_ambush and _G.dft_ambush.dir_marker_s) or 10
    CreateTimeEvent("dft", "ambush_dir_clear", ttl, function()
        clear_ambush_dir_marker()
        return true
    end)
    dft_log("Ambush dir marker: %d spots toward hostile %.0fm for %ds.",
        #dft.ambush_dir_ids, horiz, ttl)
end

path_preview_enabled = function()
    local cfg = _G.dft_config
    return cfg and cfg.path_preview == true
end

clear_path_preview = function()
    if not (dft.is_path_preview or next(dft.dot_ids or {})) then return end
    dft_cleanup_dots()
    dft.dot_ids = {}
    dft.dot_done = {}
    dft.dot_path_ratio = {}
    dft.dot_positions = {}
    dft.is_path_preview = false
    dft.path_preview_id = nil
end

local function preview_eligible(id, se_obj, ln)
    if dft_is_pda_transition(id) then
        return dft_object_on_loaded_level(se_obj), true
    end
    if is_registry_transition_door(id) then
        return dft_object_on_loaded_level(se_obj), true
    end
    if dft_is_campfire(id, se_obj) and not dft_is_cross_zone_destination(se_obj, ln) then
        return true, false
    end
    if dft_is_base(id, se_obj) and not dft_is_cross_zone_destination(se_obj, ln) then
        return true, false
    end
    return false, false
end

build_path_preview = function(id, is_lc)
    if dft.is_traveling then return end
    if not path_preview_enabled() then return end
    if not (db.actor and id) then return end

    dft_cleanup_dots()
    dft.dot_ids = {}
    dft.dot_done = {}
    dft.dot_path_ratio = {}
    dft.is_path_preview = true
    dft.path_preview_id = id

    local target = dft_resolve_travel_target(id, dft.last_menu_target_ln, dft.last_map_click_pos)
    if not target or not target.pos then
        dft.is_path_preview = false
        dft.path_preview_id = nil
        return
    end

    local start = db.actor:position()
    local dest = target.pos
    local dest_key = _G.dft_coarse_nav_dest_anchor_key and _G.dft_coarse_nav_dest_anchor_key(id) or nil
    local dist = dft_distance_pda(start, dest) or start:distance_to(dest)
    if dist < 40 and not is_lc then
        dft_log("path preview: too close (%.0fm)", dist)
        dft.is_path_preview = false
        dft.path_preview_id = nil
        return
    end

    local chain, is_vertex, path_len, raw_chain, path_meta = build_line_snap_path(start, dest, dest_key)
    if #chain < 2 then
        dft_log("path preview: coarse path failed (%.0fm straight)", dist)
        dft.is_path_preview = false
        dft.path_preview_id = nil
        return
    end

    if dft.menu_open_seq then
        dft.menu_path_cache = {
            seq = dft.menu_open_seq,
            id = id,
            chain = chain,
            is_vertex = is_vertex,
            path_len = path_len,
            raw_chain = raw_chain,
            meta = path_meta,
        }
    end

    local journey_dots = densify_polyline(chain, dft_path.dot_spacing_m, nil, path_meta)
    local markers = build_preview_markers(chain, raw_chain)
    dft.dot_positions = {}
    for i, m in ipairs(markers) do
        dft.dot_positions[i] = m.pos
    end
    dft.dot_count = #markers
    dft_log("path preview: %d waypoints, %d debug markers, %d journey dots @ %dm (path %.0fm, straight %.0fm)",
        #chain, #markers, #journey_dots, dft_path.dot_spacing_m, path_len or dist, dist)

    local spawned = 0
    for i = 1, dft.dot_count do
        local before = dft.dot_ids[i]
        local spot = markers[i] and markers[i].spot or dft_path.dot_spot_debug_edge
        ensure_path_dot(i, true, spot)
        if dft.dot_ids[i] and not before then spawned = spawned + 1 end
    end
    if spawned < dft.dot_count then
        dft_log("path preview: spawned %d/%d map dots (alife_create may have failed for some)", spawned, dft.dot_count)
    end
end

