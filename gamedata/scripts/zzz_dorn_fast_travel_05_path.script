    _G.dft_clear_ambush_dir_marker = clear_ambush_dir_marker
    _G.dft_show_ambush_dir_marker = show_ambush_dir_marker
    _G.dft_preview_eligible = preview_eligible
    _G.dft_ensure_level_graph_cache = ensure_level_graph_cache
    _G.dft_graph_nearest_gvid = graph_nearest_gvid
    _G.dft_graph_gvid_from_lvid = graph_gvid_from_lvid
