do
    _G.dft_emission_blocks_travel_start = dft_emission_blocks_travel_start
    _G.dft_advance_travel_time_seconds = dft_advance_travel_time_seconds
    _G.dft_close_pda_for_travel = dft_close_pda_for_travel
    _G.dft_start_travel_sequence = dft_start_travel_sequence
    _G.dft_check_and_skip_surges = dft_check_and_skip_surges
    _G.dft_set_safety_active = dft_set_safety_active
    _G.dft_is_safety_active = dft_is_safety_active
    _G.dft_actor_on_update = dft_actor_on_update
    _G.dft_process_refund = dft_process_refund
    _G.dft_stop_travel_logic = dft_stop_travel_logic
    _G.dft_cleanup_dots = dft_cleanup_dots
    _G.dft_teleport_companions = dft_teleport_companions
end
