local function dft_format_msg(fmt, ...)
    local arg = {...}
    if #arg == 0 then return tostring(fmt) end
    local ok, res = pcall(string.format, fmt, ...)
    return ok and res or (tostring(fmt) .. " (format error)")
end

local function dft_log(fmt, ...)
    if not CONFIG.debug_log then return end
    printf("[DFT] " .. dft_format_msg(fmt, ...))
end

local function dft_path_road_log_enabled()
    if CONFIG.debug_log then return true end
    if CONFIG.path_preview and dft.is_path_preview then return true end
    return false
end

local function dft_path_road_log(fmt, ...)
    if not dft_path_road_log_enabled() then return end
    printf("[DFT path-road] " .. dft_format_msg(fmt, ...))
end

local function dft_log_error(fmt, ...)
    printf("[DFT ERROR] " .. dft_format_msg(fmt, ...))
end

-- Used by PDA menu, guide travel, and messages — must be defined before those callers.
local function dft_str(id)
    local s = game.translate_string(id)
    if s and s ~= "" and s ~= id then return s end
    return id
end

local function destination_on_other_level(obj)
    if not (obj and db.actor) then return false end
    local gg = game_graph()
    if not gg then return false end
    local ok_a, actor_lid = pcall(function() return gg:vertex(db.actor:game_vertex_id()):level_id() end)
    local ok_d, dest_lid = pcall(function() return gg:vertex(obj.m_game_vertex_id):level_id() end)
    return ok_a and ok_d and actor_lid ~= dest_lid
end

-- True when object's game-graph level matches the actor's loaded level (not PDA tab name).
local function dft_object_on_loaded_level(se_obj)
    if not (se_obj and db.actor and game_graph) then return true end
    local gg = game_graph()
    local obj_gvid = se_obj.m_game_vertex_id
    if not (obj_gvid and gg.valid_vertex_id and gg:valid_vertex_id(obj_gvid)) then
        return not destination_on_other_level(se_obj)
    end
    local ok_a, actor_lid = pcall(function() return gg:vertex(db.actor:game_vertex_id()):level_id() end)
    local ok_o, obj_lid = pcall(function() return gg:vertex(obj_gvid):level_id() end)
    return ok_a and ok_o and actor_lid == obj_lid
end

local dft_ensure_level_graph_cache
local dft_graph_nearest_gvid
local dft_graph_gvid_from_lvid
