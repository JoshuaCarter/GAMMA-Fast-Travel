    player_ready        = true,
    start_pos           = nil,
    dest_pos            = nil,
    dest_lvid           = nil,
    dest_gvid           = nil,
    final_gvid          = nil,
    final_pos           = nil,
    final_lvid          = nil,
    travel_dist         = 0,
    current_dist        = 0,
    last_update_tg      = 0,
    next_update         = 0,
    orig_time_factor    = 1.0,
    target_time_factor  = 15,
    is_transition       = false,
    start_game_time     = nil,
    last_encounter_check = 0,
    last_event_msg      = 0,
    last_positive_event = 0,
    journey_cost        = 0,
    dynamic_map         = {}, -- [src_lvl][dst_lvl] = true
    door_registry       = {}, -- [src_lvl][dst_lvl] = {ids}
    level_names         = {}, -- [lid] = name
    dot_positions       = {},
    dot_ids             = {},
    active_config       = {},
    travel_mode         = "normal",
    encounters_avoided  = 0,
    arrival_forced_ambushes = 0,
    ambush_targets      = nil,  -- { squads={}, npcs={} } when ambush confirmed
    encumbrance_time_mult = 1.0,
}

