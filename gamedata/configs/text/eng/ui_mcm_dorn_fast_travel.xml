<string_table>
	<string id="ui_mcm_menu_dorn_fast_travel">
		<text>Dorn's Fast Travel</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_main_section">
		<text>Main</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_development_section">
		<text>Development</text>
	</string>

	<string id="ui_mcm_dorn_fast_travel_enabled">
		<text>Enable Mod</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_enabled_desc">
		<text>Enable or disable animated PDA travel.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_travel_speed">
		<text>Travel Speed</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_travel_speed_desc">
		<text>How quickly the journey bar advances on the PDA map (m/s virtual). Default 50; range 25-100.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_time_factor">
		<text>Time Factor</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_time_factor_desc">
		<text>Multiplier for real-time journey speed. Default 1 (hardest); higher values finish the PDA bar faster.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_resource_cost_mult">
		<text>Survival Cost Multiplier</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_resource_cost_mult_desc">
		<text>Scales hunger, thirst, and sleep drain from travel time. Minimum 1 (cannot make travel easier than default).</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_message_duration">
		<text>Message Duration</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_message_duration_desc">
		<text>How long on-screen travel messages stay visible (seconds).</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_arrival_offset">
		<text>Arrival Offset</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_arrival_offset_desc">
		<text>Meters before your destination to spawn instead of on top of it (0-30, default 10).</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_encounter_offset">
		<text>Ambush Spawn Offset</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_encounter_offset_desc">
		<text>Meters to pull back along your path when an ambush interrupts travel. Default 30; lower is harsher.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_map_dots_per_km">
		<text>Path Markers per km</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_map_dots_per_km_desc">
		<text>Markers placed along the route (3-30 per km of distance, clamped to 3-30 total). Used for testing density; actual count scales with trip length.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_stealth_dodge_base">
		<text>Base Sneak Chance (Scouting Lv 1)</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_stealth_dodge_base_desc">
		<text>Starting ambush dodge chance before Scouting levels and conditions. Default 20%; can only be lowered.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_night_sneak_bonus">
		<text>Night Sneak Bonus</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_night_sneak_bonus_desc">
		<text>Flat bonus percent at night (21:00-05:00). Default 20%; can only be lowered.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_rain_sneak_bonus">
		<text>Rain Sneak Bonus</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_rain_sneak_bonus_desc">
		<text>Flat bonus percent while it is raining. Default 10%; can only be lowered.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_map_dots">
		<text>Path Markers</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_map_dots_desc">
		<text>Deprecated - use Path Markers per km.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_path_marker_icon">
		<text>Path Marker Icon</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_path_marker_icon_desc">
		<text>Map spot icon for path markers. Not all options are implemented yet.</text>
	</string>
	<string id="ui_mcm_lst_green_location">
		<text>Green dot</text>
	</string>
	<string id="ui_mcm_lst_level_changer">
		<text>Zone exit arrow</text>
	</string>
	<string id="ui_mcm_lst_primary_object">
		<text>White circle</text>
	</string>
	<string id="ui_mcm_lst_artefact_location">
		<text>Artefact marker</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_path_draw_mode">
		<text>Path Draw Mode</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_path_draw_mode_desc">
		<text>How the travel route is drawn on the PDA. Only dots is implemented; other modes are reserved.</text>
	</string>
	<string id="ui_mcm_lst_dots">
		<text>Dots</text>
	</string>
	<string id="ui_mcm_lst_line">
		<text>Line (planned)</text>
	</string>
	<string id="ui_mcm_lst_walking_icon">
		<text>Walking icon (planned)</text>
	</string>
	<string id="ui_mcm_lst_none">
		<text>None (planned)</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_enable_guide_travel">
		<text>Enable Guided Instant Travel</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_enable_guide_travel_desc">
		<text>Instant teleport to any valid map destination (including cross-zone). Ruble cost only - no journey, ambush, or hunger/thirst/sleep drain.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_guide_cost_per_km">
		<text>Guide Cost per km</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_guide_cost_per_km_desc">
		<text>Rubles per 1000 meters of travel distance. Default 2000; can only be increased.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_debug_overlay">
		<text>Debug Overlay</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_debug_overlay_desc">
		<text>Show on-screen debug summary (sneak rolls, trip stats).</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_debug_log">
		<text>Debug Log</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_debug_log_desc">
		<text>Write detailed travel debug lines to xray_khada.log via printf. Errors always log regardless of this setting.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_scouting_level_up">
		<text>Scouting Level Up</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_scouting_level_up_desc">
		<text>Development keybind: increase Scouting skill level by 1.</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_scouting_level_down">
		<text>Scouting Level Down</text>
	</string>
	<string id="ui_mcm_dorn_fast_travel_scouting_level_down_desc">
		<text>Development keybind: decrease Scouting skill level by 1.</text>
	</string>

	<string id="dft_menu_travel_here">
		<text>Travel here</text>
	</string>
	<string id="dft_menu_sneaky_travel">
		<text>Sneak here</text>
	</string>
	<string id="dft_msg_hostiles_nearby">
		<text>Hostiles are too close - deal with them before traveling.</text>
	</string>
	<string id="dft_msg_cross_zone_denied">
		<text>You can only fast travel within the current zone. Use a zone exit or hire a guide.</text>
	</string>
	<string id="dft_msg_zone_exit_reached">
		<text>Zone exit reached.</text>
	</string>
	<string id="dft_msg_arrival_ambush">
		<text>Hostiles at destination - dropped short %d time(s) (unavoidable ambush).</text>
	</string>
	<string id="dft_msg_encounters_avoided">
		<text>You avoided %d encounter(s) along the way.</text>
	</string>
	<string id="dft_msg_no_encounters">
		<text>No encounters to avoid along the way.</text>
	</string>
	<string id="dft_msg_guide_paid">
		<text>Guide hired: %d RU paid.</text>
	</string>
</string_table>
