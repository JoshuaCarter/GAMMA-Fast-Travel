<!-- Dorn's Fast Travel: path dots on the PDA map (grey = ahead, green = passed,
     blue = dodged a threat here, red = ambushed here; ambush also shows green_location pin) -->
<dft_path_dot>
	<level_map spot="dft_path_dot_spot"/>
</dft_path_dot>
<dft_path_dot_spot x="0" y="0" width="4" height="4" alignment="c" scale="1" scale_min="1" scale_max="1.5" stretch="0">
	<texture>ui_dorn_path_dot_green</texture>
</dft_path_dot_spot>

<dft_path_dot_pending>
	<level_map spot="dft_path_dot_pending_spot"/>
</dft_path_dot_pending>
<dft_path_dot_pending_spot x="0" y="0" width="4" height="4" alignment="c" scale="1" scale_min="1" scale_max="1.5" stretch="0">
	<texture>ui_dorn_path_dot_grey</texture>
</dft_path_dot_pending_spot>

<dft_path_dot_ambush>
	<level_map spot="dft_path_dot_ambush_spot"/>
</dft_path_dot_ambush>
<dft_path_dot_ambush_spot x="0" y="0" width="4" height="4" alignment="c" scale="1" scale_min="1" scale_max="1.5" stretch="0">
	<texture>ui_dorn_path_dot_red</texture>
</dft_path_dot_ambush_spot>

<dft_path_dot_dodge>
	<level_map spot="dft_path_dot_dodge_spot"/>
</dft_path_dot_dodge>
<dft_path_dot_dodge_spot x="0" y="0" width="4" height="4" alignment="c" scale="1" scale_min="1" scale_max="1.5" stretch="0">
	<texture>ui_dorn_path_dot_blue</texture>
</dft_path_dot_dodge_spot>

<!-- Path preview debug: green = snapped navmesh vertex, grey = edge sample -->
<dft_path_debug_vertex>
	<level_map spot="dft_path_debug_vertex_spot"/>
</dft_path_debug_vertex>
<dft_path_debug_vertex_spot x="0" y="0" width="4" height="4" alignment="c" scale="1" scale_min="1" scale_max="2" stretch="0">
	<texture>ui_dorn_path_dot_green</texture>
</dft_path_debug_vertex_spot>

<dft_path_debug_edge>
	<level_map spot="dft_path_debug_edge_spot"/>
</dft_path_debug_edge>
<dft_path_debug_edge_spot x="0" y="0" width="2" height="2" alignment="c" scale="1" scale_min="1" scale_max="1.5" stretch="0">
	<texture>ui_dorn_path_dot_grey</texture>
</dft_path_debug_edge_spot>

<!-- Yellow ring segment for ambush detection radius (TLRA-style PDA circle outline) -->
<dft_ambush_range_ring>
	<level_map spot="dft_ambush_range_ring_spot"/>
</dft_ambush_range_ring>
<dft_ambush_range_ring_spot x="0" y="0" width="6" height="6" alignment="c" stretch="0" scale="1" scale_min="1" scale_max="1.5">
	<texture a="140" r="255" g="242" b="11" x="633" y="789" width="31" height="31">ui\ui_common</texture>
</dft_ambush_range_ring_spot>
